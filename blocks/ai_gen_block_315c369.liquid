      "id": "input_border_color",
      "label": "Input border color",
      "default": "#dfdfdf"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "submit_button_color",
      "label": "Submit button color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "submit_button_text_color",
      "label": "Submit button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "submit_button_hover_color",
      "label": "Submit button hover color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "submit_button_radius",
      "label": "Submit button radius",
      "min": 0,
      "max": 40,
