{% doc %}
  @prompt
    ad a Logo Middle Position with adjustable highet and Width no Padding Also Overlay on below Section 20%, Keep it in The Middle of the Screen , keep it as logo but near the top header or like Eybrow section but keep the logo image in the Centre of the Header section 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-logo-header-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .ai-logo-header-container-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-logo-header-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .ai-logo-header-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    position: relative;
  }

  .ai-logo-header-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-header-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #666;
    text-align: center;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-header-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding_mobile }}px 0;
    }

    .ai-logo-header-container-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width_mobile }}px;
      height: {{ block.settings.logo_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-header-wrapper-{{ ai_gen_id }}">
    <div class="ai-logo-header-container-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 1000 }}"
          alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
          class="ai-logo-header-image-{{ ai_gen_id }}"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
          loading="lazy"
        >
      {% else %}
        <div class="ai-logo-header-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-logo-header-empty-state-{{ ai_gen_id }}">
            Add your logo
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Logo header center",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Desktop width",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Desktop height",
      "min": 30,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Mobile width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Mobile height",
      "min": 30,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Desktop vertical padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "vertical_padding_mobile",
      "label": "Mobile vertical padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Logo header center"
    }
  ]
}
{% endschema %}
