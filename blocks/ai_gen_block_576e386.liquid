      "label": "Quote form ID",
      "default": "main-quote",
      "info": "Enter the ID of your quote form for smooth scrolling"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
