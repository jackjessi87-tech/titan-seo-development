                </div>

                <div class="ai-recent-jobs-route-divider-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <polyline points="19 12 12 19 5 12"></polyline>
                  </svg>
                </div>

                <div class="ai-recent-jobs-route-item-{{ ai_gen_id }}">
                  <span class="ai-recent-jobs-route-icon-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                      <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                  </span>
                  <span>{{ job.dropoff_suburb.value }}</span>
                </div>
              </div>

              <div class="ai-recent-jobs-details-{{ ai_gen_id }}">
                {% if job.item_type.value %}
                  <span class="ai-recent-jobs-chip-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">📦</span>
                    {{ job.item_type.value }}
                  </span>
                {% endif %}

                {% if job.service_type.value %}
                  <span class="ai-recent-jobs-chip-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">🚚</span>
                    {{ job.service_type.value }}
                  </span>
                {% endif %}

                {% if job.job_date.value %}
                  <span class="ai-recent-jobs-chip-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">📅</span>
                    {{ job.job_date.value | date: "%b %d, %Y" }}
                  </span>
                {% endif %}

                {% if job.customer_rating.value %}
                  <span class="ai-recent-jobs-chip-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">⭐</span>
                    {{ job.customer_rating.value }}/5
                  </span>
                {% endif %}
              </div>

              {% if job.short_description.value %}
                <p class="ai-recent-jobs-description-{{ ai_gen_id }}">{{ job.short_description.value }}</p>
              {% endif %}

              {% if block.settings.show_trust_badges %}
                <div class="ai-recent-jobs-badges-{{ ai_gen_id }}">
                  <div class="ai-recent-jobs-badge-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-badge-icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    Oversized Van
                  </div>
                  <div class="ai-recent-jobs-badge-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-badge-icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    Furniture Protected
                  </div>
                  <div class="ai-recent-jobs-badge-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-badge-icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    Professional Equipment
                  </div>
                  <div class="ai-recent-jobs-badge-{{ ai_gen_id }}">
                    <span class="ai-recent-jobs-badge-icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    Same Day Available
                  </div>
                </div>
              {% endif %}

              {% if block.settings.show_quote_button %}
                <div class="ai-recent-jobs-cta-{{ ai_gen_id }}">
                  <a 
                    href="#{{ block.settings.quote_form_id }}" 
                    class="ai-recent-jobs-button-{{ ai_gen_id }}"
                    aria-label="Get a quote for similar delivery"
                  >
                    Get Similar Delivery Quote
                  </a>
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    {% if block.settings.enable_popup %}
      <div class="ai-recent-jobs-modal-{{ ai_gen_id }}" role="dialog" aria-modal="true" aria-labelledby="modal-title-{{ ai_gen_id }}">
        <div class="ai-recent-jobs-modal-content-{{ ai_gen_id }}">
          <button class="ai-recent-jobs-modal-close-{{ ai_gen_id }}" aria-label="Close modal">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <div class="ai-recent-jobs-modal-inner-{{ ai_gen_id }}"></div>
        </div>
      </div>
    {% endif %}
  </recent-delivery-jobs-{{ ai_gen_id }}>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": [
      {% for job in recent_jobs %}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "item": {
            "@type": "Service",
            "name": "{{ job.job_title.value | escape }}",
            "description": "{{ job.short_description.value | escape }}",
            {% if job.image %}
            "image": "{{ job.image | image_url: width: 1200 }}",
            {% endif %}
            "serviceType": "{{ job.service_type.value | escape }}",
            "areaServed": {
              "@type": "Place",
              "name": "{{ job.pickup_suburb.value | escape }} to {{ job.dropoff_suburb.value | escape }}"
            },
            {% if job.job_date.value %}
            "datePublished": "{{ job.job_date.value }}",
            {% endif %}
            {% if job.customer_rating.value %}
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": "{{ job.customer_rating.value }}",
              "bestRating": "5"
            },
            {% endif %}
            "provider": {
              "@type": "Organization",
              "name": "Titan Express"
            }
          }
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
  </script>

  <script>
    (function() {
      class RecentDeliveryJobs{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
          this.jobs = {{ recent_jobs | json }};
        }

        connectedCallback() {
          {% if block.settings.enable_popup %}
            this.setupModal();
          {% endif %}
          this.setupSmoothScroll();
        }

        {% if block.settings.enable_popup %}
        setupModal() {
          const cards = this.querySelectorAll('.ai-recent-jobs-card-{{ ai_gen_id }}');
          const modal = this.querySelector('.ai-recent-jobs-modal-{{ ai_gen_id }}');
          const modalInner = this.querySelector('.ai-recent-jobs-modal-inner-{{ ai_gen_id }}');
          const closeBtn = this.querySelector('.ai-recent-jobs-modal-close-{{ ai_gen_id }}');

          cards.forEach((card) => {
            card.addEventListener('click', (e) => {
              if (e.target.closest('.ai-recent-jobs-button-{{ ai_gen_id }}')) {
                return;
              }
              const index = parseInt(card.dataset.jobIndex);
              this.openModal(index, modal, modalInner);
            });

            card.addEventListener('keydown', (e) => {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                const index = parseInt(card.dataset.jobIndex);
                this.openModal(index, modal, modalInner);
              }
            });
          });

          closeBtn.addEventListener('click', () => {
            this.closeModal(modal);
          });

          modal.addEventListener('click', (e) => {
            if (e.target === modal) {
              this.closeModal(modal);
            }
          });

          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal.classList.contains('active')) {
              this.closeModal(modal);
            }
          });
        }

        openModal(index, modal, modalInner) {
          const job = this.jobs[index];
          
          let imageHtml = '';
          if (job.image) {
            const imageUrl = job.image.replace(/\.(jpg|jpeg|png|gif|webp)/i, '_1200x.$1');
            const altText = `${job.item_type?.value || 'Item'} delivery from ${job.pickup_suburb?.value || ''} to ${job.dropoff_suburb?.value || ''} by Titan Express`;
            imageHtml = `<img src="${imageUrl}" alt="${altText}" class="ai-recent-jobs-modal-image-{{ ai_gen_id }}" loading="lazy">`;
          }

          const formattedDate = job.job_date?.value ? new Date(job.job_date.value).toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' }) : '';

          modalInner.innerHTML = `
            ${imageHtml}
            <div class="ai-recent-jobs-modal-body-{{ ai_gen_id }}">
              <h3 id="modal-title-{{ ai_gen_id }}" class="ai-recent-jobs-modal-title-{{ ai_gen_id }}">${job.job_title?.value || ''}</h3>
              
              <div class="ai-recent-jobs-modal-route-{{ ai_gen_id }}">
                <div class="ai-recent-jobs-route-item-{{ ai_gen_id }}">
                  <span class="ai-recent-jobs-route-icon-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                  </span>
                  <span>${job.pickup_suburb?.value || ''}</span>
                </div>
                <div class="ai-recent-jobs-route-divider-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <polyline points="19 12 12 19 5 12"></polyline>
                  </svg>
                </div>
                <div class="ai-recent-jobs-route-item-{{ ai_gen_id }}">
                  <span class="ai-recent-jobs-route-icon-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                  </span>
                  <span>Titan Express</span>
                </div>
                <div class="ai-recent-jobs-route-divider-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <polyline points="19 12 12 19 5 12"></polyline>
                  </svg>
                </div>
                <div class="ai-recent-jobs-route-item-{{ ai_gen_id }}">
                  <span class="ai-recent-jobs-route-icon-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#008060" stroke-width="2">
                      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                      <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                  </span>
                  <span>${job.dropoff_suburb?.value || ''}</span>
                </div>
              </div>

              <div class="ai-recent-jobs-modal-details-{{ ai_gen_id }}">
                ${job.item_type?.value ? `<span class="ai-recent-jobs-chip-{{ ai_gen_id }}"><span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">📦</span>${job.item_type.value}</span>` : ''}
                ${job.service_type?.value ? `<span class="ai-recent-jobs-chip-{{ ai_gen_id }}"><span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">🚚</span>${job.service_type.value}</span>` : ''}
                ${formattedDate ? `<span class="ai-recent-jobs-chip-{{ ai_gen_id }}"><span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">📅</span>${formattedDate}</span>` : ''}
                ${job.customer_rating?.value ? `<span class="ai-recent-jobs-chip-{{ ai_gen_id }}"><span class="ai-recent-jobs-chip-icon-{{ ai_gen_id }}">⭐</span>${job.customer_rating.value}/5</span>` : ''}
              </div>

              ${job.short_description?.value ? `<p class="ai-recent-jobs-modal-description-{{ ai_gen_id }}">${job.short_description.value}</p>` : ''}

              <div class="ai-recent-jobs-modal-cta-{{ ai_gen_id }}">
                <a href="#{{ block.settings.quote_form_id }}" class="ai-recent-jobs-modal-button-{{ ai_gen_id }}">Get My Quote</a>
              </div>
            </div>
          `;

          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }

        closeModal(modal) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
        {% endif %}

        setupSmoothScroll() {
          const buttons = this.querySelectorAll('a[href^="#"]');
          buttons.forEach(button => {
            button.addEventListener('click', (e) => {
              const targetId = button.getAttribute('href').substring(1);
              const targetElement = document.getElementById(targetId);
              
              if (targetElement) {
                e.preventDefault();
                {% if block.settings.enable_popup %}
                const modal = this.querySelector('.ai-recent-jobs-modal-{{ ai_gen_id }}');
                if (modal && modal.classList.contains('active')) {
                  this.closeModal(modal);
                }
                {% endif %}
                setTimeout(() => {
                  targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 100);
              }
            });
          });
        }
      }

      customElements.define('recent-delivery-jobs-{{ ai_gen_id }}', RecentDeliveryJobs{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
