      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 100,
      "max": 500,
      "step": 50,
      "unit": "ms",
      "default": 300
