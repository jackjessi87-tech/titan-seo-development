<script>
  (function() {
    class TitanHero{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initChips();
      }

      initChips() {
        const chips = this.querySelectorAll('.titan-hero-chip-{{ai_gen_id}}');
        chips.forEach(chip => {
          chip.addEventListener('click', () => {
            chip.style.transform = 'scale(1.1)';
            setTimeout(() => {
              chip.style.transform = 'scale(1)';
            }, 200);
          });
        });
      }
    }

    customElements.define('titan-hero-{{ai_gen_id}}', TitanHero{{ai_gen_id}});
  })();
</script>

