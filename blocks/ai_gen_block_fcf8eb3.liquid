{% doc %}
  @prompt
    Create a Shopify Liquid section called "Recent Jobs" for a furniture removalist/moving company website. Use the page metafield custom.recent_jobs, which is a list of Recent Job metaobject references. Loop through page.metafields.custom.recent_jobs.value and display each selected Recent Job dynamically as a card. Each metaobject entry may include fields such as: job_title, location, date, description, and image. Display the image (if present) using image_url and img_tag filters. Format the date nicely. Style the cards in a clean responsive grid (2-3 columns on desktop, 1 column on mobile). Include a section heading (editable via schema settings) like "Recent Jobs". Add schema settings for: section heading text, heading alignment, background color, and number of columns. Make it mobile-friendly with no horizontal overflow.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recent-jobs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-recent-jobs-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-recent-jobs-heading-{{ ai_gen_id }} {
    margin: 0 0 32px;
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: 32px;
    font-weight: 700;
  }

  .ai-recent-jobs-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 24px;
  }

  .ai-recent-jobs-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-recent-jobs-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-recent-jobs-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    background-color: #f5f5f5;
    overflow: hidden;
  }

  .ai-recent-jobs-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recent-jobs-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-recent-jobs-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-recent-jobs-content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-recent-jobs-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.card_text_color }};
  }

  .ai-recent-jobs-meta-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 14px;
    color: {{ block.settings.card_meta_color }};
  }

  .ai-recent-jobs-location-{{ ai_gen_id }},
  .ai-recent-jobs-date-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-recent-jobs-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.card_text_color }};
  }

  .ai-recent-jobs-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-recent-jobs-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .ai-recent-jobs-heading-{{ ai_gen_id }} {
      font-size: 28px;
      margin-bottom: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-recent-jobs-{{ ai_gen_id }} {
      padding: 32px 16px;
    }

    .ai-recent-jobs-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: 16px;
    }

    .ai-recent-jobs-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 20px;
    }

    .ai-recent-jobs-content-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-recent-jobs-title-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<recent-jobs-{{ ai_gen_id }} class="ai-recent-jobs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-recent-jobs-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-recent-jobs-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if page.metafields.custom.recent_jobs.value != blank %}
      <div class="ai-recent-jobs-grid-{{ ai_gen_id }}">
        {% for job in page.metafields.custom.recent_jobs.value %}
          <div class="ai-recent-jobs-card-{{ ai_gen_id }}">
            <div class="ai-recent-jobs-image-wrapper-{{ ai_gen_id }}">
              {% if job.image %}
                <img
                  src="{{ job.image | image_url: width: 800 }}"
                  alt="{{ job.job_title | escape }}"
                  class="ai-recent-jobs-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="533"
                >
              {% else %}
                <div class="ai-recent-jobs-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-recent-jobs-content-{{ ai_gen_id }}">
              {% if job.job_title %}
                <h3 class="ai-recent-jobs-title-{{ ai_gen_id }}">{{ job.job_title }}</h3>
              {% endif %}

              <div class="ai-recent-jobs-meta-{{ ai_gen_id }}">
                {% if job.location %}
                  <div class="ai-recent-jobs-location-{{ ai_gen_id }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    <span>{{ job.location }}</span>
                  </div>
                {% endif %}

                {% if job.date %}
                  <div class="ai-recent-jobs-date-{{ ai_gen_id }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span>{{ job.date | date: "%B %d, %Y" }}</span>
                  </div>
                {% endif %}
              </div>

              {% if job.description %}
                <p class="ai-recent-jobs-description-{{ ai_gen_id }}">{{ job.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-recent-jobs-empty-{{ ai_gen_id }}">
        <p>No recent jobs to display. Add jobs to the page metafield to see them here.</p>
      </div>
    {% endif %}
  </div>
</recent-jobs-{{ ai_gen_id }}>

<script>
  (function() {
    class RecentJobs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('recent-jobs-{{ ai_gen_id }}', RecentJobs{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Recent jobs",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent Jobs"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_meta_color",
      "label": "Card meta text",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Recent jobs"
    }
  ]
}
{% endschema %}