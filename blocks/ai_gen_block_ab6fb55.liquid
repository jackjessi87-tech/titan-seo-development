{% doc %}
  @prompt
    Create a modern comparison table section titled "Why Choose Titan Express?" with subheading "See how we compare to Airtasker and DIY van hire". Three columns: Titan Express (centre, highlighted with amber border and "Most Trusted" badge), Airtasker, DIY Van Hire. Seven comparison rows with icons: 1) Fixed Price - Yes / Varies / No; 2) Fully Insured - Yes / Sometimes / No; 3) Same-Day Available - Yes / Sometimes / No; 4) Equipment Included (blankets, trolleys) - Yes / Sometimes / No; 5) Trained Professionals - Yes / Unknown / Self; 6) No Hidden Fees - Yes / Platform fees apply / Fuel & extras; 7) 5-Star Google Rating - Yes / Mixed / N/A. Green checkmarks for Titan Express, red X or orange warning for others. CTA button below: "Book Titan Express Today" in amber. White background, clean minimal design, fully mobile responsive - scrollable table on small screens.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-comparison-table__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-comparison-table__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 32px;
    -webkit-overflow-scrolling: touch;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
  }

  .ai-comparison-table__header-row-{{ ai_gen_id }} {
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: 24px 16px;
    text-align: center;
    font-weight: 600;
    font-size: {{ block.settings.header_size }}px;
    color: {{ block.settings.text_color }};
    position: relative;
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}--highlighted {
    background-color: {{ block.settings.highlight_bg_color }};
    border: 3px solid {{ block.settings.highlight_border_color }};
    border-bottom: none;
  }

  .ai-comparison-table__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .ai-comparison-table__company-name-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.header_size }}px;
    font-weight: 700;
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: 20px 16px;
    text-align: center;
    font-size: {{ block.settings.cell_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}--highlighted {
    background-color: {{ block.settings.highlight_bg_color }};
    border-left: 3px solid {{ block.settings.highlight_border_color }};
    border-right: 3px solid {{ block.settings.highlight_border_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:last-child .ai-comparison-table__cell-{{ ai_gen_id }}--highlighted {
    border-bottom: 3px solid {{ block.settings.highlight_border_color }};
  }

  .ai-comparison-table__feature-{{ ai_gen_id }} {
    text-align: left;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-comparison-table__check-{{ ai_gen_id }} {
    color: {{ block.settings.check_color }};
    font-size: 24px;
    font-weight: 700;
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
    font-size: 24px;
    font-weight: 700;
  }

  .ai-comparison-table__warning-{{ ai_gen_id }} {
    color: {{ block.settings.warning_color }};
    font-size: 24px;
    font-weight: 700;
  }

  .ai-comparison-table__cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 32px;
  }

  .ai-comparison-table__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-comparison-table__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-comparison-table__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      padding: 16px 8px;
      font-size: {{ block.settings.header_size | times: 0.85 }}px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }} {
      padding: 16px 8px;
      font-size: {{ block.settings.cell_size | times: 0.9 }}px;
    }

    .ai-comparison-table__badge-{{ ai_gen_id }} {
      font-size: 10px;
      padding: 4px 8px;
    }

    .ai-comparison-table__wrapper-{{ ai_gen_id }} {
      margin-left: -20px;
      margin-right: -20px;
      padding: 0 20px;
    }
  }
{% endstyle %}

