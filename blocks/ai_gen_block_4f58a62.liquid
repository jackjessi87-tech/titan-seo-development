    background: linear-gradient(90deg, transparent 0%, {{ block.settings.accent_color }}44 50%, transparent 100%);
    margin: clamp(56px, 8vw, 88px) 0;
  }

  @media (max-width: 749px) {
    .ai-page-main-content-{{ ai_gen_id }} table {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  .ai-page-content-empty-{{ ai_gen_id }} {
    padding: clamp(60px, 10vw, 120px) 20px;
    text-align: center;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    font-size: clamp(15px, 2vw, 17px);
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-page-content-{{ ai_gen_id }} * {
      transition: none !important;
      animation: none !important;
    }
  }
{% endstyle %}

<dynamic-page-content-{{ ai_gen_id }} class="ai-page-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-page-content-container-{{ ai_gen_id }}">
    {% if page.content != blank %}
      {% if block.settings.show_hero_image and block.settings.hero_image %}
        <div class="ai-page-hero-image-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.hero_image | image_url: width: 2400 }}"
            alt="{{ block.settings.hero_heading | default: page.title | escape }}"
            loading="eager"
            width="{{ block.settings.hero_image.width }}"
            height="{{ block.settings.hero_image.height }}"
          >
          <div class="ai-page-hero-overlay-{{ ai_gen_id }}">
            <h1 class="ai-page-hero-heading-{{ ai_gen_id }}">
              {% if block.settings.hero_heading != blank %}
                {{ block.settings.hero_heading }}
              {% else %}
                {{ page.title }}
              {% endif %}
            </h1>
          </div>
        </div>
      {% endif %}

      <div class="ai-page-content-layout-{{ ai_gen_id }}" data-has-toc="false">
        {% if block.settings.show_toc %}
          <aside class="ai-page-toc-{{ ai_gen_id }}">
            <div class="ai-page-toc-sticky-{{ ai_gen_id }}">
              <button class="ai-page-toc-mobile-toggle-{{ ai_gen_id }}" aria-expanded="false">
                <span>{{ block.settings.toc_title }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <nav class="ai-page-toc-content-{{ ai_gen_id }}" aria-label="Table of contents">
                <h2 class="ai-page-toc-title-{{ ai_gen_id }}">{{ block.settings.toc_title }}</h2>
                <ul class="ai-page-toc-list-{{ ai_gen_id }}"></ul>
              </nav>
            </div>
          </aside>
        {% endif %}

        <article class="ai-page-main-content-{{ ai_gen_id }}">
          {{ page.content }}
        </article>
      </div>
    {% else %}
      <div class="ai-page-content-empty-{{ ai_gen_id }}">
        Add content to this page to see it displayed with premium typography
      </div>
    {% endif %}
  </div>
</dynamic-page-content-{{ ai_gen_id }}>

<script>
  (function() {
    class DynamicPageContent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tocEnabled = {{ block.settings.show_toc | json }};
        this.highlightEnabled = {{ block.settings.enable_highlighting | json }};
        this.highlightKeywords = {{ block.settings.highlight_keywords | json }};
      }

      connectedCallback() {
        this.content = this.querySelector('.ai-page-main-content-{{ ai_gen_id }}');
        if (!this.content) return;

        this.addAnchorIds();

        if (this.tocEnabled) {
          this.generateTableOfContents();
          this.setupSmoothScrolling();
          this.setupScrollSpy();
          this.setupMobileToggle();
        }

        if (this.highlightEnabled && this.highlightKeywords) {
          this.highlightContent();
        }

        this.enhanceImages();
        this.enhanceTypography();
      }

      addAnchorIds() {
        const headings = this.content.querySelectorAll('h1, h2, h3, h4, h5, h6');
        headings.forEach((heading) => {
          if (!heading.id) {
            const id = heading.textContent
              .toLowerCase()
              .replace(/[^\w\s-]/g, '')
              .replace(/\s+/g, '-')
              .replace(/--+/g, '-')
              .trim();
            heading.id = id || 'heading-' + Math.random().toString(36).substr(2, 9);
          }
        });
      }

      generateTableOfContents() {
        const headings = this.content.querySelectorAll('h2, h3');
        if (headings.length === 0) return;

        const tocList = this.querySelector('.ai-page-toc-list-{{ ai_gen_id }}');
        if (!tocList) return;

        const layout = this.querySelector('.ai-page-content-layout-{{ ai_gen_id }}');
        if (layout) {
          layout.setAttribute('data-has-toc', 'true');
        }

        headings.forEach((heading) => {
          const li = document.createElement('li');
          li.className = 'ai-page-toc-item-{{ ai_gen_id }} ' + heading.tagName.toLowerCase();

          const link = document.createElement('a');
          link.className = 'ai-page-toc-link-{{ ai_gen_id }}';
          link.href = '#' + heading.id;
          link.textContent = heading.textContent;

          li.appendChild(link);
          tocList.appendChild(li);
        });
      }

      setupSmoothScrolling() {
        const links = this.querySelectorAll('.ai-page-toc-link-{{ ai_gen_id }}');
        links.forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('href').substring(1);
            const target = document.getElementById(targetId);
            if (target) {
              const offset = 120;
              const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
              window.scrollTo({
                top: targetPosition,
                behavior: 'smooth'
              });

              if (window.innerWidth < 990) {
                const toggle = this.querySelector('.ai-page-toc-mobile-toggle-{{ ai_gen_id }}');
                const content = this.querySelector('.ai-page-toc-content-{{ ai_gen_id }}');
                if (toggle && content) {
                  toggle.classList.remove('active');
                  content.classList.remove('active');
                  toggle.setAttribute('aria-expanded', 'false');
                }
              }
            }
          });
        });
      }

      setupScrollSpy() {
        const links = this.querySelectorAll('.ai-page-toc-link-{{ ai_gen_id }}');
        const headings = this.content.querySelectorAll('h2, h3');

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                links.forEach((link) => link.classList.remove('active'));
                const activeLink = this.querySelector(
                  `.ai-page-toc-link-{{ ai_gen_id }}[href="#${entry.target.id}"]`
                );
                if (activeLink) {
                  activeLink.classList.add('active');
                }
              }
            });
          },
          {
            rootMargin: '-120px 0px -66%',
            threshold: 0
          }
        );

        headings.forEach((heading) => observer.observe(heading));
      }

      setupMobileToggle() {
        const toggle = this.querySelector('.ai-page-toc-mobile-toggle-{{ ai_gen_id }}');
        const content = this.querySelector('.ai-page-toc-content-{{ ai_gen_id }}');

        if (toggle && content) {
          toggle.addEventListener('click', () => {
            const isActive = toggle.classList.contains('active');
            toggle.classList.toggle('active');
            content.classList.toggle('active');
            toggle.setAttribute('aria-expanded', !isActive);
          });
        }
      }

      highlightContent() {
        if (!this.highlightKeywords) return;

        const keywords = this.highlightKeywords
          .split(',')
          .map((k) => k.trim())
          .filter((k) => k.length > 0);

        if (keywords.length === 0) return;

        const textNodes = this.getTextNodes(this.content);
        const pattern = new RegExp('\\b(' + keywords.join('|') + ')\\b', 'gi');

        textNodes.forEach((node) => {
          const parent = node.parentNode;
          if (parent.tagName === 'SCRIPT' || parent.tagName === 'STYLE') return;
          if (parent.classList.contains('ai-highlight-{{ ai_gen_id }}')) return;

          const text = node.textContent;
          if (pattern.test(text)) {
            const fragment = document.createDocumentFragment();
            let lastIndex = 0;
            text.replace(pattern, (match, p1, offset) => {
              if (offset > lastIndex) {
                fragment.appendChild(
                  document.createTextNode(text.substring(lastIndex, offset))
                );
              }
              const mark = document.createElement('mark');
              mark.className = 'ai-highlight-{{ ai_gen_id }}';
              mark.style.cssText = `
                background: linear-gradient(to bottom, transparent 50%, {{ block.settings.highlight_color }} 50%);
                padding: 2px 8px;
                border-radius: 4px;
                font-weight: 700;
                color: {{ block.settings.heading_color }};
              `;
              mark.textContent = match;
              fragment.appendChild(mark);
              lastIndex = offset + match.length;
            });
            if (lastIndex < text.length) {
              fragment.appendChild(document.createTextNode(text.substring(lastIndex)));
            }
            parent.replaceChild(fragment, node);
          }
        });
      }

      enhanceImages() {
        const images = this.content.querySelectorAll('img');
        images.forEach((img) => {
          img.loading = 'lazy';
        });
      }

      enhanceTypography() {
        const paragraphs = this.content.querySelectorAll('p');
        paragraphs.forEach((p) => {
          if (p.textContent.trim().length === 0) {
            p.style.display = 'none';
          }
        });
      }

      getTextNodes(element) {
        const textNodes = [];
        const walker = document.createTreeWalker(
          element,
          NodeFilter.SHOW_TEXT,
          null,
          false
        );
        let node;
        while ((node = walker.nextNode())) {
          if (node.textContent.trim().length > 0) {
            textNodes.push(node);
          }
        }
        return textNodes;
      }
    }

    customElements.define('dynamic-page-content-{{ ai_gen_id }}', DynamicPageContent{{ ai_gen_id }});
  })();
</script>

