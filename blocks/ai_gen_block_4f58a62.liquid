{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-page-content-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-page-content-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  @media (min-width: 750px) {
    .ai-page-content-container-{{ ai_gen_id }} {
      padding: 0 40px;
    }
  }

  .ai-page-hero-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.hero_height_mobile }}px;
    overflow: hidden;
    margin: 0 0 clamp(40px, 8vw, 80px);
  }

  @media (min-width: 750px) {
    .ai-page-hero-image-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height }}px;
      border-radius: {{ block.settings.image_border_radius }}px;
    }
  }

  .ai-page-hero-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-page-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0) 0%,
      rgba(0,0,0,{{ block.settings.overlay_opacity }}) 70%,
      rgba(0,0,0,{{ block.settings.overlay_opacity | plus: 0.2 }}) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: clamp(24px, 5vw, 60px);
  }

  .ai-page-hero-heading-{{ ai_gen_id }} {
    color: #ffffff;
    font-size: clamp(32px, 6vw, {{ block.settings.hero_heading_size }}px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    text-shadow: 0 4px 24px rgba(0,0,0,0.5);
    max-width: 900px;
  }

  .ai-page-content-layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 6vw, 80px);
    margin: clamp(40px, 8vw, 100px) 0;
  }

  @media (min-width: 990px) {
    .ai-page-content-layout-{{ ai_gen_id }}[data-has-toc="true"] {
      grid-template-columns: 300px 1fr;
      gap: clamp(60px, 8vw, 120px);
    }
  }

  .ai-page-toc-{{ ai_gen_id }} {
    position: relative;
  }

  @media (min-width: 990px) {
    .ai-page-toc-sticky-{{ ai_gen_id }} {
      position: sticky;
      top: 120px;
      align-self: start;
    }
  }

  .ai-page-toc-mobile-toggle-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 24px;
    background-color: {{ block.settings.toc_background }};
    border: 2px solid {{ block.settings.accent_color }};
    border-radius: {{ block.settings.toc_border_radius }}px;
    cursor: pointer;
    font-weight: 700;
    font-size: 15px;
    color: {{ block.settings.heading_color }};
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: 0.3px;
  }

  .ai-page-toc-mobile-toggle-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accent_color }};
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.2);
  }

  .ai-page-toc-mobile-toggle-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-page-toc-mobile-toggle-{{ ai_gen_id }}.active svg {
    transform: rotate(180deg);
  }

  @media (min-width: 990px) {
    .ai-page-toc-mobile-toggle-{{ ai_gen_id }} {
      display: none;
    }
  }

  .ai-page-toc-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.toc_background }};
    border: 2px solid {{ block.settings.toc_border_color }};
    border-radius: {{ block.settings.toc_border_radius }}px;
    padding: 28px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-page-toc-content-{{ ai_gen_id }}.active {
    max-height: 800px;
    opacity: 1;
    margin-top: 16px;
  }

  @media (min-width: 990px) {
    .ai-page-toc-content-{{ ai_gen_id }} {
      max-height: none;
      opacity: 1;
      margin-top: 0;
    }
  }

  .ai-page-toc-title-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.2px;
