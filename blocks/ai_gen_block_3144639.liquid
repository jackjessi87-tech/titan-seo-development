  .ai-seo-btn-alt-{{ ai_gen_id }}:hover {
    background: #ffffff;
    color: #000000;
    box-shadow: 0 6px 20px rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 1199px) {
    .ai-seo-layout-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .ai-seo-sidebar-{{ ai_gen_id }} {
      display: none;
    }

    .ai-seo-toc-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }

  @media (max-width: 749px) {
    .ai-seo-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 20px;
    }

    .ai-seo-hero-{{ ai_gen_id }} {
      padding: 32px 26px;
    }

    .ai-seo-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-seo-features-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-seo-links-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-seo-cta-{{ ai_gen_id }} {
      padding: 40px 28px;
    }

    .ai-seo-cta-btns-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-seo-btn-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<div class="ai-seo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-seo-container-{{ ai_gen_id }}">
    <div class="ai-seo-layout-{{ ai_gen_id }}">
      
      <aside class="ai-seo-sidebar-{{ ai_gen_id }}" data-sidebar>
        <div class="ai-seo-toc-card-{{ ai_gen_id }}">
          <div class="ai-seo-toc-title-{{ ai_gen_id }}">On This Page</div>
          <nav aria-label="Table of contents">
            <ul class="ai-seo-toc-nav-{{ ai_gen_id }}" data-toc-list></ul>
          </nav>
        </div>
      </aside>

      <div class="ai-seo-toc-mobile-{{ ai_gen_id }}" data-toc-mobile>
        <button class="ai-seo-toc-toggle-{{ ai_gen_id }}" data-toc-toggle aria-expanded="false">
          <span>Table of Contents</span>
          <svg class="ai-seo-toc-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div class="ai-seo-toc-drawer-{{ ai_gen_id }}">
          <nav aria-label="Table of contents">
            <ul class="ai-seo-toc-nav-{{ ai_gen_id }}" data-toc-list-mobile></ul>
          </nav>
        </div>
      </div>

      <div class="ai-seo-main-{{ ai_gen_id }}">
        
        {% if service_name != blank or intro_content != blank or service_description != blank %}
          <div class="ai-seo-hero-{{ ai_gen_id }}">
            <h1 class="ai-seo-h1-{{ ai_gen_id }}">
              {% if service_name != blank and suburb_name != blank %}
                {{ service_name }} in {{ suburb_name }}
              {% elsif service_name != blank %}
                Professional {{ service_name }} - {{ shop.name }}
              {% else %}
                {{ page.title }}
              {% endif %}
            </h1>
            
            {% if intro_content.type == 'rich_text_field' %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ intro_content | metafield_tag }}
              </div>
            {% elsif service_description.type == 'rich_text_field' %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ service_description | metafield_tag }}
              </div>
            {% elsif intro_content != blank %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ intro_content }}
              </div>
            {% elsif service_description != blank %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ service_description }}
              </div>
            {% elsif service_summary != blank %}
              <p class="ai-seo-lead-{{ ai_gen_id }}">{{ service_summary }}</p>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-seo-content-{{ ai_gen_id }} rte" data-content itemscope itemtype="https://schema.org/Article">
          <meta itemprop="headline" content="{{ page.title }}">
          {% if page.published_at %}
            <meta itemprop="datePublished" content="{{ page.published_at | date: '%Y-%m-%d' }}">
          {% endif %}
          {% if page.updated_at %}
            <meta itemprop="dateModified" content="{{ page.updated_at | date: '%Y-%m-%d' }}">
          {% endif %}
          <div itemprop="articleBody">
            {{ page.content }}
          </div>
        </div>

        {% if service_benefits != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">Why Choose Our {% if service_name != blank %}{{ service_name }}{% else %}Service{% endif %}{% if suburb_name != blank %} in {{ suburb_name }}{% endif %}</h2>
            <div class="ai-seo-grid-{{ ai_gen_id }}">
              {% assign benefits = service_benefits | split: ',' %}
              {% for benefit in benefits limit: 6 %}
                <div class="ai-seo-card-{{ ai_gen_id }}">
                  <svg class="ai-seo-card-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <div class="ai-seo-card-title-{{ ai_gen_id }}">{{ benefit | strip }}</div>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if process_steps != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">How Our {% if service_name != blank %}{{ service_name }}{% else %}Service{% endif %} Works</h2>
            <div class="ai-seo-steps-{{ ai_gen_id }}">
              {% assign steps = process_steps | split: '|' %}
              {% for step in steps limit: 5 %}
                {% assign parts = step | split: ':' %}
                {% if parts.size == 2 %}
                  <div class="ai-seo-step-{{ ai_gen_id }}">
                    <div class="ai-seo-step-num-{{ ai_gen_id }}">{{ forloop.index }}</div>
                    <div class="ai-seo-step-body-{{ ai_gen_id }}">
                      <h3 class="ai-seo-step-title-{{ ai_gen_id }}">{{ parts[0] | strip }}</h3>
                      <p class="ai-seo-step-text-{{ ai_gen_id }}">{{ parts[1] | strip }}</p>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if key_features != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">What's Included</h2>
            <div class="ai-seo-features-{{ ai_gen_id }}">
              {% assign features = key_features | split: ',' %}
              {% for feature in features limit: 12 %}
                <div class="ai-seo-feature-{{ ai_gen_id }}">
                  <svg class="ai-seo-check-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span>{{ feature | strip }}</span>
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if additional_content != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            {% if additional_content.type == 'rich_text_field' %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ additional_content | metafield_tag }}
              </div>
            {% else %}
              <div class="ai-seo-richtext-{{ ai_gen_id }} rte">
                {{ additional_content }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if service_areas != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">Service Areas{% if suburb_name != blank %} Near {{ suburb_name }}{% endif %}</h2>
            <p>We provide professional {% if service_name != blank %}{{ service_name | downcase }}{% else %}services{% endif %} across the following Sydney locations:</p>
            <div class="ai-seo-areas-{{ ai_gen_id }}">
              {% assign areas = service_areas | split: ',' %}
              {% for area in areas %}
                <span class="ai-seo-area-{{ ai_gen_id }}">{{ area | strip }}</span>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if related_services != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">Related Services</h2>
            <div class="ai-seo-links-{{ ai_gen_id }}">
              {% assign services = related_services | split: '|' %}
              {% for service in services limit: 6 %}
                {% assign parts = service | split: ':' %}
                {% if parts.size == 2 %}
                  <a href="{{ parts[1] | strip }}" class="ai-seo-link-card-{{ ai_gen_id }}">
                    <div class="ai-seo-link-title-{{ ai_gen_id }}">{{ parts[0] | strip }}</div>
                    <div class="ai-seo-link-arrow-{{ ai_gen_id }}">Learn more →</div>
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if faqs != blank %}
          <div class="ai-seo-section-{{ ai_gen_id }}">
            <h2 class="ai-seo-section-head-{{ ai_gen_id }}">Frequently Asked Questions</h2>
            <div class="ai-seo-faqs-{{ ai_gen_id }}" itemscope itemtype="https://schema.org/FAQPage">
              {% assign faq_items = faqs | split: '|' %}
              {% for faq in faq_items limit: 8 %}
                {% assign parts = faq | split: '?' %}
                {% if parts.size == 2 %}
                  <div class="ai-seo-faq-{{ ai_gen_id }}" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 class="ai-seo-faq-q-{{ ai_gen_id }}" itemprop="name">{{ parts[0] | strip }}?</h3>
                    <div class="ai-seo-faq-a-{{ ai_gen_id }}" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                      <div itemprop="text">{{ parts[1] | strip }}</div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        <div class="ai-seo-cta-{{ ai_gen_id }}">
          <h2 class="ai-seo-cta-title-{{ ai_gen_id }}">
            {% if cta_text != blank %}
              {{ cta_text }}
            {% else %}
              Ready to Book{% if service_name != blank %} Your {{ service_name }}{% endif %}?
            {% endif %}
          </h2>
          <p class="ai-seo-cta-desc-{{ ai_gen_id }}">
            Get a free quote in minutes. Professional service, competitive pricing, and reliable results guaranteed.
          </p>
          <div class="ai-seo-cta-btns-{{ ai_gen_id }}">
            <a href="{{ block.settings.quote_url }}" class="ai-seo-btn-{{ ai_gen_id }}">
              Get Free Quote
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
            {% if block.settings.phone != blank %}
              <a href="tel:{{ block.settings.phone }}" class="ai-seo-btn-{{ ai_gen_id }} ai-seo-btn-alt-{{ ai_gen_id }}">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                {{ block.settings.phone }}
              </a>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    class AiSeo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.content = this.querySelector('[data-content]');
        this.sidebar = this.querySelector('[data-sidebar]');
        this.tocMobile = this.querySelector('[data-toc-mobile]');
        this.tocToggle = this.querySelector('[data-toc-toggle]');
        this.tocList = this.querySelector('[data-toc-list]');
        this.tocListMobile = this.querySelector('[data-toc-list-mobile]');
        this.headings = [];
      }

      connectedCallback() {
        this.buildTOC();
        this.initScrollSpy();
        this.initMobileToggle();
      }

      buildTOC() {
        const allHeadings = this.querySelectorAll('h2, h3');
        
        if (allHeadings.length < 3) {
          if (this.sidebar) this.sidebar.style.display = 'none';
          if (this.tocMobile) this.tocMobile.style.display = 'none';
          return;
        }

        allHeadings.forEach((heading, idx) => {
          const tag = heading.tagName.toLowerCase();
          const id = heading.id || `heading-${tag}-${idx}-{{ ai_gen_id }}`;
          heading.id = id;
          
          this.headings.push({ el: heading, id: id, tag: tag });

          const li = document.createElement('li');
          li.className = 'ai-seo-toc-item-{{ ai_gen_id }}';

          const a = document.createElement('a');
          a.href = `#${id}`;
          a.className = tag === 'h3' 
            ? 'ai-seo-toc-link-{{ ai_gen_id }} ai-seo-toc-link-h3-{{ ai_gen_id }}'
            : 'ai-seo-toc-link-{{ ai_gen_id }}';
          a.textContent = heading.textContent;
          a.dataset.target = id;

          a.addEventListener('click', (e) => {
            e.preventDefault();
            this.scrollToHeading(heading);
          });

          li.appendChild(a);
          this.tocList.appendChild(li);

          const liMobile = li.cloneNode(true);
          const aMobile = liMobile.querySelector('a');
          aMobile.addEventListener('click', (e) => {
            e.preventDefault();
            this.scrollToHeading(heading);
            this.tocMobile.classList.remove('open');
            this.tocToggle.setAttribute('aria-expanded', 'false');
          });
          this.tocListMobile.appendChild(liMobile);
        });
      }

      scrollToHeading(el) {
        const offset = {{ block.settings.scroll_margin }};
        const pos = el.getBoundingClientRect().top + window.pageYOffset;
        window.scrollTo({
          top: pos - offset,
          behavior: 'smooth'
        });
      }

      initScrollSpy() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.activateLink(entry.target.id);
            }
          });
        }, {
          rootMargin: '-15% 0px -65% 0px',
          threshold: 0
        });

        this.headings.forEach(({ el }) => {
          observer.observe(el);
        });
      }

      activateLink(id) {
        const links = this.querySelectorAll('.ai-seo-toc-link-{{ ai_gen_id }}');
        links.forEach(link => {
          if (link.dataset.target === id) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }

      initMobileToggle() {
        if (!this.tocToggle) return;

        this.tocToggle.addEventListener('click', () => {
          const isOpen = this.tocMobile.classList.contains('open');
          
          if (isOpen) {
            this.tocMobile.classList.remove('open');
            this.tocToggle.setAttribute('aria-expanded', 'false');
          } else {
            this.tocMobile.classList.add('open');
            this.tocToggle.setAttribute('aria-expanded', 'true');
          }
        });
      }
    }

    customElements.define('ai-seo-{{ ai_gen_id }}', AiSeo{{ ai_gen_id }});
  })();
</script>

