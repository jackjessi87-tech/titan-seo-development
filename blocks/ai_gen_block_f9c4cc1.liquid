<script>
  (function() {
    class TitanServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.titan-services-card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => {
            const isExpanded = card.classList.contains('expanded');
            
            this.cards.forEach((c) => c.classList.remove('expanded'));
            
            if (!isExpanded) {
              card.classList.add('expanded');
            }
          });
        });

        document.addEventListener('click', (event) => {
          if (!event.target.closest('.titan-services-card-{{ ai_gen_id }}')) {
            this.cards.forEach((card) => card.classList.remove('expanded'));
          }
        });
      }
    }

    customElements.define('titan-services-{{ ai_gen_id }}', TitanServices{{ ai_gen_id }});
  })();
</script>

