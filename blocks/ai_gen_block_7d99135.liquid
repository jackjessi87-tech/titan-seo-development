{% doc %}
  @prompt
    Upgrade the existing "Dynamic schema generator" Liquid block (ai_gen_block_5c0e25b) on the test-page to include the following enhancements, fully compliant with Google Rich Results requirements:
    
    1. **Dynamic Multi-Area Service Area Markup**
       - Pull service area suburb/region names from page metafields (e.g. `page.metafields.custom.service_areas` as a list metafield)
       - Generate multiple `areaServed` entries in the MovingCompany JSON-LD schema, each typed as `City` or `AdministrativeArea` with a `name` property
       - If metafield is empty, fall back to a configurable default list in the block schema settings
    
    2. **AggregateRating Schema (Google Reviews)**
       - Add `aggregateRating` object to the LocalBusiness/MovingCompany schema
       - Pull `ratingValue` and `reviewCount` from page or shop metafields (e.g. `shop.metafields.custom.google_rating` and `shop.metafields.custom.google_review_count`)
       - Include `bestRating: 5` and `worstRating: 1`
       - Only output aggregateRating if both ratingValue and reviewCount metafields have values
       - Also expose these as editable fallback fields in the block schema settings
    
    3. **Google Rich Results Compliance**
       - Ensure all JSON-LD output uses correct schema.org types: `MovingCompany`, `LocalBusiness`, `FAQPage`, `WebPage`, `BreadcrumbList`
       - Include all Google-required fields: `@context`, `@type`, `name`, `url`, `telephone`, `address` (with `PostalAddress`), `aggregateRating`, `areaServed`
       - Output each schema type as a separate `<script type="application/ld+json">` block
       - Do not output a schema block if its required data is missing
    
    Keep all existing schema toggles (Organization, LocalBusiness, FAQ, WebPage, Breadcrumb), business type selector, social URL fields, and preview display settings intact.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign service_areas_metafield = page.metafields.custom.service_areas
  assign google_rating = shop.metafields.custom.google_rating
  assign google_review_count = shop.metafields.custom.google_review_count
  
  if service_areas_metafield == blank
    assign service_areas_list = block.settings.fallback_service_areas | split: ','
  else
    assign service_areas_list = service_areas_metafield
  endif
  
  if google_rating == blank
    assign rating_value = block.settings.fallback_rating_value
  else
    assign rating_value = google_rating
  endif
  
  if google_review_count == blank
    assign review_count = block.settings.fallback_review_count
  else
    assign review_count = google_review_count
  endif
%}

<div class="ai-schema-generator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_preview %}
    <div class="ai-schema-preview-{{ ai_gen_id }}">
      <h3>Schema Markup Preview</h3>
      <ul>
        {% if block.settings.enable_organization %}
          <li>✓ Organization Schema</li>
        {% endif %}
        {% if block.settings.enable_local_business %}
          <li>✓ {{ block.settings.business_type }} Schema</li>
          {% if service_areas_list.size > 0 %}
            <li style="margin-left: 20px;">→ Service Areas: {{ service_areas_list | join: ', ' }}</li>
          {% endif %}
          {% if rating_value != blank and review_count != blank %}
            <li style="margin-left: 20px;">→ Aggregate Rating: {{ rating_value }}/5 ({{ review_count }} reviews)</li>
          {% endif %}
        {% endif %}
        {% if block.settings.enable_faq %}
          <li>✓ FAQ Schema</li>
        {% endif %}
        {% if block.settings.enable_webpage %}
          <li>✓ WebPage Schema</li>
        {% endif %}
        {% if block.settings.enable_breadcrumb %}
          <li>✓ Breadcrumb Schema</li>
        {% endif %}
      </ul>
    </div>
  {% endif %}

  {% if block.settings.enable_organization %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "{{ shop.name | escape }}",
      "url": "{{ shop.url }}",
      {% if block.settings.organization_logo %}
        "logo": "{{ block.settings.organization_logo | image_url: width: 600 }}",
      {% endif %}
      {% if block.settings.social_facebook or block.settings.social_instagram or block.settings.social_twitter or block.settings.social_linkedin or block.settings.social_youtube %}
        "sameAs": [
          {% if block.settings.social_facebook != blank %}"{{ block.settings.social_facebook }}"{% if block.settings.social_instagram != blank or block.settings.social_twitter != blank or block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_instagram != blank %}"{{ block.settings.social_instagram }}"{% if block.settings.social_twitter != blank or block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_twitter != blank %}"{{ block.settings.social_twitter }}"{% if block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_linkedin != blank %}"{{ block.settings.social_linkedin }}"{% if block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_youtube != blank %}"{{ block.settings.social_youtube }}"{% endif %}
        ],
      {% endif %}
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "{{ block.settings.phone_number }}",
        "contactType": "customer service"
      }
    }
    </script>
  {% endif %}

  {% if block.settings.enable_local_business and block.settings.business_name != blank and block.settings.phone_number != blank and block.settings.street_address != blank %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ block.settings.business_type }}",
      "name": "{{ block.settings.business_name | escape }}",
      "url": "{{ shop.url }}",
      "telephone": "{{ block.settings.phone_number }}",
      {% if block.settings.business_email != blank %}
        "email": "{{ block.settings.business_email }}",
      {% endif %}
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ block.settings.street_address | escape }}",
        "addressLocality": "{{ block.settings.city | escape }}",
        "addressRegion": "{{ block.settings.state | escape }}",
        "postalCode": "{{ block.settings.postal_code }}",
        "addressCountry": "{{ block.settings.country }}"
      },
      {% if block.settings.business_image %}
        "image": "{{ block.settings.business_image | image_url: width: 1200 }}",
      {% endif %}
      {% if block.settings.price_range != blank %}
        "priceRange": "{{ block.settings.price_range }}",
      {% endif %}
      {% if rating_value != blank and review_count != blank %}
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ rating_value }}",
          "reviewCount": "{{ review_count }}",
          "bestRating": "5",
          "worstRating": "1"
        },
      {% endif %}
      {% if service_areas_list.size > 0 %}
        "areaServed": [
          {% for area in service_areas_list %}
            {
              "@type": "{% if block.settings.area_type == 'city' %}City{% else %}AdministrativeArea{% endif %}",
              "name": "{{ area | strip | escape }}"
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ],
      {% endif %}
      {% if block.settings.opening_hours != blank %}
        "openingHours": "{{ block.settings.opening_hours }}",
      {% endif %}
      {% if block.settings.social_facebook or block.settings.social_instagram or block.settings.social_twitter or block.settings.social_linkedin or block.settings.social_youtube %}
        "sameAs": [
          {% if block.settings.social_facebook != blank %}"{{ block.settings.social_facebook }}"{% if block.settings.social_instagram != blank or block.settings.social_twitter != blank or block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_instagram != blank %}"{{ block.settings.social_instagram }}"{% if block.settings.social_twitter != blank or block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_twitter != blank %}"{{ block.settings.social_twitter }}"{% if block.settings.social_linkedin != blank or block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_linkedin != blank %}"{{ block.settings.social_linkedin }}"{% if block.settings.social_youtube != blank %},{% endif %}{% endif %}
          {% if block.settings.social_youtube != blank %}"{{ block.settings.social_youtube }}"{% endif %}
        ],
      {% endif %}
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "{{ block.settings.latitude }}",
        "longitude": "{{ block.settings.longitude }}"
      }
    }
    </script>
  {% endif %}

  {% if block.settings.enable_faq and page.metafields.custom.faq_items %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for faq in page.metafields.custom.faq_items %}
          {
            "@type": "Question",
            "name": "{{ faq.question | escape }}",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "{{ faq.answer | escape }}"
            }
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
  {% endif %}

  {% if block.settings.enable_webpage %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "{{ page.title | escape }}",
      "url": "{{ canonical_url }}",
      "description": "{{ page.metafields.custom.meta_description | default: page.content | strip_html | truncate: 160 | escape }}",
      "inLanguage": "{{ request.locale.iso_code }}",
      "isPartOf": {
        "@type": "WebSite",
        "name": "{{ shop.name | escape }}",
        "url": "{{ shop.url }}"
      }
    }
    </script>
  {% endif %}

  {% if block.settings.enable_breadcrumb %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ page.title | escape }}",
          "item": "{{ canonical_url }}"
        }
      ]
    }
    </script>
  {% endif %}
</div>

{% style %}
  .ai-schema-generator-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-schema-preview-{{ ai_gen_id }} {
    background-color: {{ block.settings.preview_bg_color }};
    border: 2px solid {{ block.settings.preview_border_color }};
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .ai-schema-preview-{{ ai_gen_id }} h3 {
    margin: 0 0 15px 0;
    font-size: 18px;
    color: {{ block.settings.preview_text_color }};
  }

  .ai-schema-preview-{{ ai_gen_id }} ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-schema-preview-{{ ai_gen_id }} li {
    padding: 5px 0;
    color: {{ block.settings.preview_text_color }};
    font-size: 14px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Dynamic schema generator",
  "settings": [
    {
      "type": "header",
      "content": "Schema toggles"
    },
    {
      "type": "checkbox",
      "id": "enable_organization",
      "label": "Enable Organization schema",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_local_business",
      "label": "Enable LocalBusiness schema",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_faq",
      "label": "Enable FAQ schema",
      "default": false,
      "info": "Requires page.metafields.custom.faq_items"
    },
    {
      "type": "checkbox",
      "id": "enable_webpage",
      "label": "Enable WebPage schema",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_breadcrumb",
      "label": "Enable Breadcrumb schema",
      "default": true
    },
    {
      "type": "header",
      "content": "Business type"
    },
    {
      "type": "select",
      "id": "business_type",
      "label": "Business type",
      "options": [
        {
          "value": "LocalBusiness",
          "label": "Local Business"
        },
        {
          "value": "MovingCompany",
          "label": "Moving Company"
        },
        {
          "value": "HomeAndConstructionBusiness",
          "label": "Home & Construction"
        },
        {
          "value": "ProfessionalService",
          "label": "Professional Service"
        },
        {
          "value": "Store",
          "label": "Store"
        },
        {
          "value": "Restaurant",
          "label": "Restaurant"
        }
      ],
      "default": "MovingCompany"
    },
    {
      "type": "header",
      "content": "Organization details"
    },
    {
      "type": "image_picker",
      "id": "organization_logo",
      "label": "Organization logo"
    },
    {
      "type": "header",
      "content": "Business information"
    },
    {
      "type": "text",
      "id": "business_name",
      "label": "Business name",
      "default": "Your Business Name"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "+1-555-555-5555"
    },
    {
      "type": "text",
      "id": "business_email",
      "label": "Business email"
    },
    {
      "type": "image_picker",
      "id": "business_image",
      "label": "Business image"
    },
    {
      "type": "text",
      "id": "price_range",
      "label": "Price range",
      "info": "e.g., $$, $$$, or $50-$200"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "text",
      "id": "street_address",
      "label": "Street address",
      "default": "123 Main Street"
    },
    {
      "type": "text",
      "id": "city",
      "label": "City",
      "default": "Sydney"
    },
    {
      "type": "text",
      "id": "state",
      "label": "State/Region",
      "default": "NSW"
    },
    {
      "type": "text",
      "id": "postal_code",
      "label": "Postal code",
      "default": "2000"
    },
    {
      "type": "text",
      "id": "country",
      "label": "Country code",
      "default": "AU",
      "info": "Use ISO 3166-1 alpha-2 code (e.g., AU, US, GB)"
    },
    {
      "type": "header",
      "content": "Geographic coordinates"
    },
    {
      "type": "text",
      "id": "latitude",
      "label": "Latitude",
      "default": "-33.8688"
    },
    {
      "type": "text",
      "id": "longitude",
      "label": "Longitude",
      "default": "151.2093"
    },
    {
      "type": "header",
      "content": "Service areas"
    },
    {
      "type": "paragraph",
      "content": "Service areas are pulled from page.metafields.custom.service_areas. If empty, fallback list below is used."
    },
    {
      "type": "textarea",
      "id": "fallback_service_areas",
      "label": "Fallback service areas",
      "info": "Comma-separated list (e.g., Sydney, Melbourne, Brisbane)",
      "default": "Sydney, Melbourne, Brisbane, Perth, Adelaide"
    },
    {
      "type": "select",
      "id": "area_type",
      "label": "Area type",
      "options": [
        {
          "value": "city",
          "label": "City"
        },
        {
          "value": "administrative",
          "label": "Administrative Area"
        }
      ],
      "default": "city"
    },
    {
      "type": "header",
      "content": "Google reviews rating"
    },
    {
      "type": "paragraph",
      "content": "Rating pulled from shop.metafields.custom.google_rating and shop.metafields.custom.google_review_count. If empty, fallback values below are used."
    },
    {
      "type": "text",
      "id": "fallback_rating_value",
      "label": "Fallback rating value",
      "info": "e.g., 4.8 (leave empty to disable if metafield is empty)"
    },
    {
      "type": "text",
      "id": "fallback_review_count",
      "label": "Fallback review count",
      "info": "e.g., 127 (leave empty to disable if metafield is empty)"
    },
    {
      "type": "header",
      "content": "Business hours"
    },
    {
      "type": "text",
      "id": "opening_hours",
      "label": "Opening hours",
      "info": "e.g., Mo-Fr 09:00-17:00"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Preview display"
    },
    {
      "type": "checkbox",
      "id": "show_preview",
      "label": "Show schema preview",
      "default": false,
      "info": "Display a visual preview of active schemas (for testing only)"
    },
    {
      "type": "color",
      "id": "preview_bg_color",
      "label": "Preview background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "preview_border_color",
      "label": "Preview border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "preview_text_color",
      "label": "Preview text",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Dynamic schema generator"
    }
  ]
}
{% endschema %}