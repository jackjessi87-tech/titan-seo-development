{% doc %}
  @prompt
    Ad Faq Section For this Removalist Website Include Faq For Seo And GOOGle Ads To Pupll Data 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-faq-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px 0;
    font-weight: 700;
  }

  .ai-faq-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 20px;
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    font-weight: 600;
    margin: 0;
    flex: 1;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.7;
    padding-bottom: {{ block.settings.item_padding }}px;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-section-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-faq-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ai-faq-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-faq-question-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_size }}px * 0.9);
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_size }}px * 0.9);
    }
  }
{% endstyle %}

<removalist-faq-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-faq-header-{{ ai_gen_id }}">
        {% if block.settings.section_title != blank %}
          <h2 class="ai-faq-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <div class="ai-faq-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div itemscope itemtype="https://schema.org/FAQPage">
      <ul class="ai-faq-list-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% liquid
            assign question_key = 'faq_question_' | append: i
            assign answer_key = 'faq_answer_' | append: i
            assign question = block.settings[question_key]
            assign answer = block.settings[answer_key]
          %}

          {% if question != blank and answer != blank %}
            <li class="ai-faq-item-{{ ai_gen_id }}" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <button
                class="ai-faq-question-button-{{ ai_gen_id }}"
                aria-expanded="false"
                data-faq-toggle
              >
                <h3 class="ai-faq-question-text-{{ ai_gen_id }}" itemprop="name">{{ question }}</h3>
                <span class="ai-faq-icon-{{ ai_gen_id }}" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div class="ai-faq-answer-{{ ai_gen_id }}" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <div class="ai-faq-answer-content-{{ ai_gen_id }}" itemprop="text">{{ answer }}</div>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</removalist-faq-{{ ai_gen_id }}>

<script>
  (function() {
    class RemovalistFaq{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.faqItems = this.querySelectorAll('.ai-faq-item-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.faqItems.forEach((item) => {
          const button = item.querySelector('[data-faq-toggle]');
          const answer = item.querySelector('.ai-faq-answer-{{ ai_gen_id }}');

          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              item.classList.remove('active');
              button.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('removalist-faq-{{ ai_gen_id }}', RemovalistFaq{{ ai_gen_id }});
  })();
</script>

