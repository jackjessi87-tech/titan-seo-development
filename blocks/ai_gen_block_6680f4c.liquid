{% schema %}
{
  "name": "Local schema markup",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contact information"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "info": "Enter without +61 prefix (e.g., 412345678)",
      "default": "412345678"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "range",
      "id": "rating_value",
      "label": "Rating value",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 4.9
    },
    {
      "type": "range",
      "id": "review_count",
      "label": "Review count",
      "min": 0,
      "max": 1000,
      "step": 10,
      "default": 300
    },
    {
      "type": "header",
      "content": "Service pricing"
    },
    {
      "type": "range",
      "id": "single_item_price",
      "label": "Single item move price",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "$",
      "default": 90
    },
    {
      "type": "range",
      "id": "marketplace_pickup_price",
      "label": "Marketplace pickup price",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "$",
      "default": 90
    },
    {
      "type": "range",
      "id": "studio_move_price",
      "label": "Studio move price",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "$",
      "default": 180
    }
  ],
  "presets": [
    {
      "name": "Local schema markup"
    }
  ]
}
{% endschema %}
