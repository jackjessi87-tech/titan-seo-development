{% doc %}
  @prompt
    Create an invisible (no visual output) Liquid schema markup block that injects a JSON-LD LocalBusiness and Service structured data script into the page head for a Sydney furniture removalist service page. The schema should include: "@type": ["LocalBusiness", "MovingCompany"], "name": "Titan Express Furniture Removalists", "description": "Professional man with a van Sydney service offering same-day furniture removals, single item moves, and marketplace pickups across all Sydney suburbs. Fixed price, fully insured.", "url": dynamic page URL using Liquid, "telephone": "+61 placeholder", "priceRange": "$$", "areaServed": an array of Sydney suburbs including Sydney CBD, Bondi, Newtown, Surry Hills, Parramatta, Chatswood, Manly, Cronulla, Penrith, Liverpool, Campbelltown, Blacktown, Castle Hill, Hornsby, Mosman, Neutral Bay, Balmain, Glebe, Leichhardt, Marrickville, Randwick, Coogee, Maroubra, Hurstville, Kogarah, Strathfield, Burwood, Ashfield, Five Dock, Drummoyne, "serviceType": "Man With a Van Removalist", "aggregateRating" with ratingValue 4.9 and reviewCount 300, "openingHoursSpecification" for Monday to Sunday 7am to 7pm, and "hasOfferCatalog" listing Single Item Move from $89, Marketplace Pickup from $89, Studio Move from $180. The block should output only the JSON-LD script tag with no visible HTML. Use Liquid where appropriate for dynamic values.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

