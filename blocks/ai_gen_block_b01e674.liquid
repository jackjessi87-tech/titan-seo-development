<script>
  (function() {
    class SydneyServiceAreas{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupQuoteButton();
      }

      setupQuoteButton() {
        const quoteButton = this.querySelector('[data-scroll-to-quote]');
        if (quoteButton) {
          quoteButton.addEventListener('click', function() {
            const quoteSection = document.querySelector('[data-quote-form]');
            if (quoteSection) {
              quoteSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        }
      }
    }

    customElements.define('sydney-service-areas-{{ ai_gen_id }}', SydneyServiceAreas{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Sydney service areas",
  "settings": [
    {
      "type": "header",
