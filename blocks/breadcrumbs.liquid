{%- doc -%}
  Reusable visible breadcrumb trail for service landing pages: Home > Page title.

  Uses the same two sources (shop.url, page.title/canonical_url) as the
  BreadcrumbList JSON-LD in blocks/service-schema.liquid, so the visible
  trail and the structured data can never disagree with each other.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

<nav
  class="breadcrumbs breadcrumbs--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  aria-label="Breadcrumb"
  {{ block.shopify_attributes }}
>
  <ol class="breadcrumbs__list">
    <li class="breadcrumbs__item">
      <a class="breadcrumbs__link" href="{{ shop.url }}">Home</a>
    </li>
    <li class="breadcrumbs__item" aria-current="page">
      <span class="breadcrumbs__current">{{ page.title }}</span>
    </li>
  </ol>
</nav>

{% stylesheet %}
  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--page-width, 1280px);
    margin-inline: auto;
    padding-inline: var(--padding-md, 16px);
    font-size: var(--font-paragraph-small--size, 0.875rem);
  }

  .breadcrumbs__item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
  }

  .breadcrumbs__item:not(:last-child)::after {
    content: "/";
    margin-left: 6px;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.5));
  }

  .breadcrumbs__link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .breadcrumbs__link:hover,
  .breadcrumbs__link:focus-visible {
    color: var(--color-foreground);
    border-bottom-color: currentColor;
  }

  .breadcrumbs__current {
    color: var(--color-foreground);
    font-weight: var(--font-weight-semibold, 600);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs"
    }
  ]
}
{% endschema %}
