    <header class="recent-deliveries-header-{{ ai_gen_id }}">
      <div class="recent-deliveries-label-{{ ai_gen_id }}">Recent Deliveries</div>
      <h2 class="recent-deliveries-heading-{{ ai_gen_id }}">
        {% if area_name != blank %}
          <span class="recent-deliveries-heading-line1-{{ ai_gen_id }}">Recent Deliveries</span>
          <span class="recent-deliveries-heading-line2-{{ ai_gen_id }}"> in <span class="recent-deliveries-area-name-{{ ai_gen_id }}">{{ area_name }}</span></span>
        {% else %}
          {{ heading_text }}
        {% endif %}
      </h2>
      <p class="recent-deliveries-subheading-{{ ai_gen_id }}">{{ subheading_text }}</p>
    </header>

    <div class="recent-deliveries-grid-{{ ai_gen_id }}">
      {% for job in recent_jobs %}
        {% liquid
          assign pickup = job.pickup_suburb.value
          assign dropoff = job.drop_off_suburb.value
          assign item = job.item.value
          assign service = job.service_type.value
          assign description = job.short_description.value
          assign image = job.image.value
          assign job_date = job.job_date.value
          assign rating = job.rating.value
          assign related_suburbs = job.related_suburbs.value
          assign related_services = job.related_services.value
          assign price_range = job.price_range.value
          assign job_title = job.recent_job.value

          assign alt_text = ''
          if item != blank and area_name != blank
            assign alt_text = item | append: ' delivery completed in ' | append: area_name | append: ' by Titan Express'
          elsif item != blank and pickup != blank
            assign alt_text = item | append: ' delivery from ' | append: pickup
            if dropoff != blank
              assign alt_text = alt_text | append: ' to ' | append: dropoff
            endif
            assign alt_text = alt_text | append: ' by Titan Express'
          elsif job_title != blank
            assign alt_text = job_title | append: ' - Titan Express'
          else
            assign alt_text = 'Furniture delivery by Titan Express'
          endif
        %}

        <article class="delivery-card-{{ ai_gen_id }}">
          <div class="delivery-card-inner-{{ ai_gen_id }}">
            <div class="delivery-card-image-wrapper-{{ ai_gen_id }}">
              {% if image != blank %}
                <img
                  src="{{ image | image_url: width: 280 }}"
                  alt="{{ alt_text | escape }}"
                  width="280"
                  height="280"
                  loading="lazy"
                  class="delivery-card-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="delivery-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="delivery-card-content-{{ ai_gen_id }}">
              {% if job_title != blank %}
                <h3 class="delivery-card-title-{{ ai_gen_id }}">{{ job_title }}</h3>
              {% endif %}

              {% if pickup != blank or dropoff != blank %}
                <div class="delivery-card-route-{{ ai_gen_id }}">
                  {% if pickup != blank %}
                    <svg class="delivery-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    <span>{{ pickup }}</span>
                  {% endif %}
                  {% if pickup != blank and dropoff != blank %}
                    <svg class="delivery-card-route-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  {% endif %}
                  {% if dropoff != blank %}
                    <svg class="delivery-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <path d="M9 10l2 2 4-4"></path>
                    </svg>
                    <span>{{ dropoff }}</span>
                  {% endif %}
                </div>
              {% endif %}

              {% if item != blank or service != blank %}
                <div class="delivery-card-meta-{{ ai_gen_id }}">
                  {% if item != blank %}
                    <span class="delivery-card-meta-item-{{ ai_gen_id }}">
                      <svg class="delivery-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                      </svg>
                      <span>{{ item }}</span>
                    </span>
                  {% endif %}
                  {% if item != blank and service != blank %}
                    <span class="delivery-card-meta-separator-{{ ai_gen_id }}">•</span>
                  {% endif %}
                  {% if service != blank %}
                    <span class="delivery-card-meta-item-{{ ai_gen_id }}">
                      <svg class="delivery-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                      </svg>
                      <span>{{ service }}</span>
                    </span>
                  {% endif %}
                </div>
              {% endif %}

              {% if description != blank %}
                <p class="delivery-card-description-{{ ai_gen_id }}">{{ description }}</p>
              {% endif %}

              <div class="delivery-card-footer-{{ ai_gen_id }}">
                <div class="delivery-card-date-rating-{{ ai_gen_id }}">
                  {% if job_date != blank %}
                    <div class="delivery-card-date-{{ ai_gen_id }}">
                      <svg class="delivery-card-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                      </svg>
                      <span>{{ job_date | date: '%b %d, %Y' }}</span>
                    </div>
                  {% endif %}

                  {% if rating != blank %}
                    <div class="delivery-card-rating-{{ ai_gen_id }}">
                      {% assign rating_num = rating | times: 1.0 %}
                      {% assign full_stars = rating_num | floor %}
                      {% assign has_half = rating_num | minus: full_stars %}
                      {% for i in (1..full_stars) %}
                        <svg class="delivery-card-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                      {% endfor %}
                      {% if has_half >= 0.5 %}
                        <svg class="delivery-card-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                      {% endif %}
                      {% assign remaining = 5 | minus: full_stars %}
                      {% if has_half >= 0.5 %}
                        {% assign remaining = remaining | minus: 1 %}
                      {% endif %}
                      {% for i in (1..remaining) %}
                        <svg class="delivery-card-star-{{ ai_gen_id }} delivery-card-star-empty-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>

                {% if price_range != blank %}
                  <div class="delivery-card-price-{{ ai_gen_id }}">
                    <svg class="delivery-card-price-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                      <line x1="7" y1="7" x2="7.01" y2="7"></line>
                    </svg>
                    <span>From ${{ price_range }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

          {% if related_suburbs.size > 0 or related_services.size > 0 %}
            <div class="delivery-card-tags-{{ ai_gen_id }}">
              {% for suburb in related_suburbs %}
                <span class="delivery-card-tag-{{ ai_gen_id }}">
                  <svg class="delivery-card-tag-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon>
                    <line x1="8" y1="2" x2="8" y2="18"></line>
                    <line x1="16" y1="6" x2="16" y2="22"></line>
                  </svg>
                  {{ suburb }}
                </span>
              {% endfor %}
              {% for service in related_services %}
                <span class="delivery-card-tag-{{ ai_gen_id }} delivery-card-tag-service-{{ ai_gen_id }}">
                  <svg class="delivery-card-tag-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                  </svg>
                  {{ service }}
                </span>
              {% endfor %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    {% if block.settings.button_text != blank %}
      <div class="recent-deliveries-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_url }}" class="recent-deliveries-button-{{ ai_gen_id }}" aria-label="{{ button_aria | escape }}">
          <span>{{ block.settings.button_text }}</span>
          <svg class="recent-deliveries-button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    {% endif %}
  </div>
</recent-deliveries-{{ ai_gen_id }}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ heading_text | json }},
  "description": {{ schema_description | json }},
  "itemListElement": [
    {% for job in recent_jobs %}
      {% liquid
        assign pickup = job.pickup_suburb.value
        assign dropoff = job.drop_off_suburb.value
        assign item = job.item.value
        assign service = job.service_type.value
        assign description = job.short_description.value
        assign image = job.image.value
        assign job_date = job.job_date.value
        assign rating = job.rating.value
        assign price_range = job.price_range.value
        assign job_title = job.recent_job.value
      %}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "item": {
          "@type": "Service",
          {% if job_title != blank %}
            "name": {{ job_title | json }},
          {% endif %}
          {% if description != blank %}
            "description": {{ description | json }},
          {% endif %}
          {% if image != blank %}
            "image": {{ image | image_url: width: 800 | json }},
          {% endif %}
          {% if area_name != blank %}
            "areaServed": {
              "@type": "Place",
              "name": {{ area_name | json }}
            },
          {% endif %}
          {% if service != blank %}
            "serviceType": {{ service | json }},
          {% endif %}
          {% if rating != blank %}
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": {{ rating | json }},
              "bestRating": "5"
            },
          {% endif %}
          {% if price_range != blank %}
            "offers": {
              "@type": "Offer",
              "priceSpecification": {
                "@type": "PriceSpecification",
                "price": {{ price_range | json }}
              }
            },
          {% endif %}
          "provider": {
            "@type": "Organization",
            "name": "Titan Express"
          }
        }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>

{% endif %}

{% schema %}
{
  "name": "Recent Deliveries",
  "tag": "section",
  "class": "section-recent-deliveries",
  "settings": [
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View More Deliveries"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#dc2626"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#dc2626"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#b91c1c"
    }
  ],
  "presets": [
    {
      "name": "Recent Deliveries"
    }
  ]
}
{% endschema %}
