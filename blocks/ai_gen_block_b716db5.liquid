            </label>
            <input
              type="email"
              name="contact[Customer Email]"
              class="titan-fb-form-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Pickup Suburb <span class="titan-fb-form-required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="text"
              name="contact[Pickup Suburb]"
              class="titan-fb-form-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Drop-off Suburb <span class="titan-fb-form-required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="text"
              name="contact[Drop-off Suburb]"
              class="titan-fb-form-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Item Details <span class="titan-fb-form-required-{{ ai_gen_id }}">*</span>
            </label>
            <textarea
              name="contact[Item Details]"
              class="titan-fb-form-textarea-{{ ai_gen_id }}"
              required
            ></textarea>
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Stairs or Lift? <span class="titan-fb-form-required-{{ ai_gen_id }}">*</span>
            </label>
            <select
              name="contact[Stairs or Lift]"
              class="titan-fb-form-select-{{ ai_gen_id }}"
              required
            >
              <option value="">Select option</option>
              <option value="Stairs">Stairs</option>
              <option value="Lift">Lift</option>
              <option value="Ground Floor">Ground Floor</option>
            </select>
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Preferred Date / Time <span class="titan-fb-form-required-{{ ai_gen_id }}">*</span>
            </label>
            <input
              type="text"
              name="contact[Preferred Date Time]"
              class="titan-fb-form-input-{{ ai_gen_id }}"
              placeholder="e.g., June 15, 2026 at 10:00 AM"
              required
            >
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Upload Photo (optional)
            </label>
            <input
              type="file"
              name="contact[Photo]"
              class="titan-fb-form-file-{{ ai_gen_id }}"
              accept="image/*"
            >
          </div>

          <div class="titan-fb-form-group-{{ ai_gen_id }}">
            <label class="titan-fb-form-label-{{ ai_gen_id }}">
              Extra Notes (optional)
            </label>
            <textarea
              name="contact[Extra Notes]"
              class="titan-fb-form-textarea-{{ ai_gen_id }}"
            ></textarea>
          </div>

          <button
            type="submit"
            class="titan-fb-form-submit-{{ ai_gen_id }}"
          >
            {{ block.settings.submit_button_text }}
          </button>

          {%- if form.posted_successfully? -%}
            <div class="titan-fb-success-message-{{ ai_gen_id }}">
              {{ block.settings.success_message }}
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</titan-fb-card-{{ ai_gen_id }}>

<script>
  (function() {
    class TitanFbCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hideTimeout = null;
      }

      connectedCallback() {
        const container = this.querySelector('.titan-fb-card-container-{{ ai_gen_id }}');
        const closeBtn = this.querySelector('[data-close-card]');
        const quoteBtn = this.querySelector('[data-open-quote]');
        const modalOverlay = this.querySelector('[data-modal-overlay]');
        const closeModalBtn = this.querySelector('[data-close-modal]');
        
        if (closeBtn && container) {
          closeBtn.addEventListener('click', () => {
            container.classList.add('hidden');
            
            this.hideTimeout = setTimeout(() => {
              container.classList.remove('hidden');
            }, 10000);
          });
        }

        if (quoteBtn && modalOverlay) {
          quoteBtn.addEventListener('click', () => {
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
          });
        }

        if (closeModalBtn && modalOverlay) {
          closeModalBtn.addEventListener('click', () => {
            this.closeModal(modalOverlay);
          });
        }

        if (modalOverlay) {
          modalOverlay.addEventListener('click', (e) => {
            if (e.target === modalOverlay) {
              this.closeModal(modalOverlay);
            }
          });

          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modalOverlay.classList.contains('active')) {
              this.closeModal(modalOverlay);
            }
          });
        }
      }

      closeModal(modalOverlay) {
        modalOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      disconnectedCallback() {
        if (this.hideTimeout) {
          clearTimeout(this.hideTimeout);
        }
      }
    }

    customElements.define('titan-fb-card-{{ ai_gen_id }}', TitanFbCard{{ ai_gen_id }});
  })();
</script>

