{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-removals-services-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-removals-services__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-removals-services__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-removals-services__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-removals-services__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-removals-services__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-removals-service-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-removals-service-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-removals-service-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-removals-service-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-removals-service-card__image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-removals-service-card__content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-removals-service-card__tag-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .ai-removals-service-card__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-removals-service-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .ai-removals-service-card__capacity-{{ ai_gen_id }} {
    background-color: {{ block.settings.capacity_background }};
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 16px;
  }

  .ai-removals-service-card__capacity-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px;
  }

  .ai-removals-service-card__capacity-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-removals-service-card__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-removals-service-card__list-item-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: {{ block.settings.text_color }};
    padding: 8px 0;
    border-bottom: 1px solid {{ block.settings.border_color }};
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-removals-service-card__list-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-removals-service-card__list-item-{{ ai_gen_id }}::before {
    content: "✓";
    color: {{ block.settings.checkmark_color }};
    font-weight: 700;
    font-size: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-removals-services__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-removals-services__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-removals-service-card__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_heading_size }}px * 0.9);
    }
  }
{% endstyle %}

<removals-services-{{ ai_gen_id }} class="ai-removals-services-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-removals-services__container-{{ ai_gen_id }}">
    <div class="ai-removals-services__header-{{ ai_gen_id }}">
      {% if block.settings.main_title != blank %}
        <h2 class="ai-removals-services__title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      {% endif %}
      {% if block.settings.main_subtitle != blank %}
        <div class="ai-removals-services__subtitle-{{ ai_gen_id }}">{{ block.settings.main_subtitle }}</div>
      {% endif %}
    </div>

    <div class="ai-removals-services__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign service_enabled_key = 'service_' | append: i | append: '_enabled'
          assign service_image_key = 'service_' | append: i | append: '_image'
          assign service_alt_key = 'service_' | append: i | append: '_alt_text'
          assign service_tag_key = 'service_' | append: i | append: '_tag'
          assign service_heading_key = 'service_' | append: i | append: '_heading'
          assign service_description_key = 'service_' | append: i | append: '_description'
          assign service_capacity_key = 'service_' | append: i | append: '_capacity'
          assign service_list_key = 'service_' | append: i | append: '_list'

          assign service_enabled = block.settings[service_enabled_key]
          assign service_image = block.settings[service_image_key]
          assign service_alt = block.settings[service_alt_key]
          assign service_tag = block.settings[service_tag_key]
          assign service_heading = block.settings[service_heading_key]
          assign service_description = block.settings[service_description_key]
          assign service_capacity = block.settings[service_capacity_key]
          assign service_list = block.settings[service_list_key]
        %}

        {% if service_enabled %}
          <article class="ai-removals-service-card-{{ ai_gen_id }}">
            <div class="ai-removals-service-card__image-wrapper-{{ ai_gen_id }}">
              {% if service_image %}
                <img
                  src="{{ service_image | image_url: width: 800 }}"
                  alt="{{ service_alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="533"
                  class="ai-removals-service-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>

            <div class="ai-removals-service-card__content-{{ ai_gen_id }}">
              {% if service_tag != blank %}
                <span class="ai-removals-service-card__tag-{{ ai_gen_id }}">{{ service_tag }}</span>
              {% endif %}

              {% if service_heading != blank %}
                <h3 class="ai-removals-service-card__heading-{{ ai_gen_id }}">{{ service_heading }}</h3>
              {% endif %}

              {% if service_description != blank %}
                <div class="ai-removals-service-card__description-{{ ai_gen_id }}">{{ service_description }}</div>
              {% endif %}

              {% if service_capacity != blank %}
                <div class="ai-removals-service-card__capacity-{{ ai_gen_id }}">
                  <h4 class="ai-removals-service-card__capacity-title-{{ ai_gen_id }}">Van Capacity</h4>
                  <p class="ai-removals-service-card__capacity-text-{{ ai_gen_id }}">{{ service_capacity }}</p>
                </div>
              {% endif %}

              {% if service_list != blank %}
                {% assign list_items = service_list | split: ',' %}
                <ul class="ai-removals-service-card__list-{{ ai_gen_id }}">
                  {% for item in list_items %}
                    <li class="ai-removals-service-card__list-item-{{ ai_gen_id }}">{{ item | strip }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</removals-services-{{ ai_gen_id }}>

<script>
  (function() {
    class RemovalsServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeCards();
      }

      initializeCards() {
        const cards = this.querySelectorAll('.ai-removals-service-card-{{ ai_gen_id }}');
        cards.forEach((card, index) => {
          card.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('removals-services-{{ ai_gen_id }}', RemovalsServices{{ ai_gen_id }});
  })();
</script>

