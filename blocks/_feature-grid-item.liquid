{%- doc -%}
  Nested item block for blocks/feature-grid.liquid.
  Renders one icon + H3 heading + short description tile.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

<div
  class="feature-grid__item"
  {{ block.shopify_attributes }}
>
  {%- if block_settings.icon != blank -%}
    <span class="feature-grid__icon" aria-hidden="true">
      {%- case block_settings.icon -%}
        {%- when 'van' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="15" height="10" rx="1"></rect><path d="M8 1v6M15 1v6M8 17v4M15 17v4"></path></svg>
        {%- when 'blanket' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M7 4v14M17 4v14"></path></svg>
        {%- when 'trolley' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="19" r="2"></circle><circle cx="17" cy="19" r="2"></circle><rect x="2" y="4" width="18" height="14" rx="1"></rect><line x1="6" y1="4" x2="6" y2="2"></line></svg>
        {%- when 'experience' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 6 6 .9-4.5 4.3 1 6.3-5.5-3-5.5 3 1-6.3L3 8.9 9 8z"></path></svg>
        {%- when 'single-item' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="8" width="16" height="9" rx="2"></rect><path d="M9 5v3M15 5v3M4 17l-1 3h18l-1-3"></path></svg>
        {%- when 'map' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 20l-6-3V4l6 3 6-3 6 3v13l-6-3-6 3z"></path><line x1="9" y1="4" x2="9" y2="23"></line><line x1="15" y1="7" x2="15" y2="23"></line></svg>
        {%- when 'two-workers' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="3"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        {%- when 'location' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        {%- when 'size' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 3 3 21"></path><path d="M8 21l-5-5M13 21l-5-5M21 8l-5-5"></path></svg>
        {%- when 'stairs' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h4v-4h4v-4h4V8h4V4"></path></svg>
        {%- when 'parking' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M9 9h6a2 2 0 0 1 0 4H9v4M9 7v10"></path></svg>
        {%- when 'workers' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="3"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M15 3.13a4 4 0 0 1 0 7.75"></path></svg>
        {%- when 'clock' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        {%- when 'marketplace' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l1.5-5h15L21 9"></path><path d="M3 9h18v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9z"></path><line x1="9" y1="9" x2="9" y2="19"></line><line x1="15" y1="9" x2="15" y2="19"></line></svg>
        {%- when 'sofa-bed' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 11v6h20v-6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"></path><rect x="2" y="5" width="20" height="6" rx="1"></rect></svg>
        {%- when 'recliner' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 13V6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v7"></path><path d="M11 6v11h10V8a2 2 0 0 0-2-2h-6a2 2 0 0 0-2 2"></path><rect x="2" y="17" width="20" height="3" rx="1"></rect></svg>
        {%- when 'corner' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V9a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2h6a2 2 0 0 1 2 2v8"></path><path d="M9 9V3h6v6"></path><rect x="2" y="17" width="20" height="4" rx="1"></rect></svg>
        {%- when 'leather' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="10" width="20" height="8" rx="2"></rect><path d="M6 10V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v5"></path></svg>
        {%- when 'modular' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="9" width="9" height="9" rx="1"></rect><rect x="13" y="9" width="9" height="9" rx="1"></rect><rect x="2" y="2" width="9" height="5" rx="1"></rect></svg>
        {%- when 'sofa-2' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12V8a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4h4V8a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4"></path><rect x="2" y="14" width="20" height="6" rx="1"></rect></svg>
        {%- when 'sofa-3' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12V8a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v4h6V8a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v4"></path><rect x="2" y="14" width="20" height="6" rx="1"></rect></svg>
      {%- endcase -%}
    </span>
  {%- endif -%}
  <h3 class="feature-grid__item-heading">{{ block_settings.heading }}</h3>
  {%- if block_settings.text != blank -%}
    <p class="feature-grid__item-text">{{ block_settings.text }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Feature item",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H3)",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Short description"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "", "label": "None" },
        { "value": "sofa-2", "label": "Two-seater sofa" },
        { "value": "sofa-3", "label": "Three-seater sofa" },
        { "value": "modular", "label": "Modular sofa" },
        { "value": "sofa-bed", "label": "Sofa bed" },
        { "value": "recliner", "label": "Recliner" },
        { "value": "corner", "label": "Corner lounge" },
        { "value": "leather", "label": "Leather sofa" },
        { "value": "marketplace", "label": "Marketplace" },
        { "value": "van", "label": "Van" },
        { "value": "blanket", "label": "Blanket" },
        { "value": "trolley", "label": "Trolley" },
        { "value": "experience", "label": "Experience" },
        { "value": "single-item", "label": "Single item" },
        { "value": "map", "label": "Map / coverage" },
        { "value": "two-workers", "label": "One or two workers" },
        { "value": "location", "label": "Location pin" },
        { "value": "size", "label": "Size / ruler" },
        { "value": "stairs", "label": "Stairs" },
        { "value": "parking", "label": "Parking" },
        { "value": "workers", "label": "Workers" },
        { "value": "clock", "label": "Clock / urgency" }
      ],
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Feature item"
    }
  ]
}
{% endschema %}