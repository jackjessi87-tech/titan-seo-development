<script>
  (function() {
    class InstantQuoteForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentStep = 1;
        this.totalSteps = 8;
        this.formData = {};
      }

      connectedCallback() {
        this.scrollTrigger = parseInt(this.dataset.scrollTrigger) || 5;
        this.setupElements();
        this.setupEventListeners();
        this.loadSavedData();
        this.checkScroll();
      }

      setupElements() {
        this.overlay = this.querySelector('.ai-quote-form-overlay-{{ ai_gen_id }}');
        this.closeBtn = this.querySelector('.ai-quote-form-close-{{ ai_gen_id }}');
        this.backBtn = this.querySelector('.ai-quote-form-back-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-quote-form-next-{{ ai_gen_id }}');
        this.progressBar = this.querySelector('.ai-quote-form-progress-bar-{{ ai_gen_id }}');
        this.steps = this.querySelectorAll('.ai-quote-form-step-{{ ai_gen_id }}');
        this.form = this.querySelector('form');
        this.successDiv = this.querySelector('.ai-quote-form-success-{{ ai_gen_id }}');
        this.contentDiv = this.querySelector('.ai-quote-form-content-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        window.addEventListener('scroll', () => this.checkScroll());
        this.overlay.addEventListener('click', () => this.closeForm());
        this.closeBtn.addEventListener('click', () => this.closeForm());
        this.backBtn.addEventListener('click', () => this.previousStep());
        this.nextBtn.addEventListener('click', () => this.nextStep());

        this.querySelectorAll('.ai-quote-form-option-{{ ai_gen_id }}').forEach(option => {
          option.addEventListener('click', (e) => this.selectOption(e));
        });

        this.querySelectorAll('.ai-quote-form-input-{{ ai_gen_id }}').forEach(input => {
          input.addEventListener('input', () => this.saveData());
        });

        this.form.addEventListener('submit', (e) => this.handleSubmit(e));
      }

      checkScroll() {
        const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (scrollPercent >= this.scrollTrigger && !this.classList.contains('ai-visible-{{ ai_gen_id }}')) {
          this.showForm();
        }
      }

      showForm() {
        this.classList.add('ai-visible-{{ ai_gen_id }}');
        document.body.style.overflow = 'hidden';
      }

      closeForm() {
        this.classList.remove('ai-visible-{{ ai_gen_id }}');
        document.body.style.overflow = '';
      }

      selectOption(e) {
        const option = e.target;
        const step = option.closest('.ai-quote-form-step-{{ ai_gen_id }}');
        const stepNum = parseInt(step.dataset.step);
        
        step.querySelectorAll('.ai-quote-form-option-{{ ai_gen_id }}').forEach(opt => {
          opt.classList.remove('ai-selected-{{ ai_gen_id }}');
        });
        
        option.classList.add('ai-selected-{{ ai_gen_id }}');
        
        if (stepNum === 3) {
          this.querySelector('.ai-quote-form-moving-value-{{ ai_gen_id }}').value = option.dataset.value;
        } else if (stepNum === 4) {
          this.querySelector('.ai-quote-form-access-value-{{ ai_gen_id }}').value = option.dataset.value;
        }
        
        this.saveData();
        
        setTimeout(() => {
          this.nextStep();
        }, 300);
      }

      nextStep() {
        const currentStepEl = this.steps[this.currentStep - 1];
        const inputs = currentStepEl.querySelectorAll('input[required]');
        let isValid = true;

        inputs.forEach(input => {
          if (!input.value.trim()) {
            isValid = false;
            input.focus();
          }
        });

        if (this.currentStep === 3 || this.currentStep === 4) {
          const hiddenInput = currentStepEl.querySelector('input[type="hidden"]');
          if (!hiddenInput.value) {
            isValid = false;
          }
        }

        if (!isValid) return;

        if (this.currentStep < this.totalSteps) {
          this.currentStep++;
          this.updateStep();
        } else {
          this.form.submit();
        }
      }

      previousStep() {
        if (this.currentStep > 1) {
          this.currentStep--;
          this.updateStep();
        }
      }

      updateStep() {
        this.steps.forEach((step, index) => {
          if (index === this.currentStep - 1) {
            step.classList.add('ai-active-{{ ai_gen_id }}');
          } else {
            step.classList.remove('ai-active-{{ ai_gen_id }}');
          }
        });

        const progress = (this.currentStep / this.totalSteps) * 100;
        this.progressBar.style.width = progress + '%';

        if (this.currentStep === 1) {
          this.backBtn.style.display = 'none';
        } else {
          this.backBtn.style.display = 'block';
        }

        if (this.currentStep === this.totalSteps) {
          this.nextBtn.innerHTML = 'Get My Fast Quote →';
        } else {
          this.nextBtn.innerHTML = 'Next →';
        }
      }

      saveData() {
        const formData = new FormData(this.form);
        const data = {};
        for (let [key, value] of formData.entries()) {
          data[key] = value;
        }
        localStorage.setItem('ai-quote-form-{{ ai_gen_id }}', JSON.stringify(data));
      }

      loadSavedData() {
        const saved = localStorage.getItem('ai-quote-form-{{ ai_gen_id }}');
        if (saved) {
          const data = JSON.parse(saved);
          Object.keys(data).forEach(key => {
            const input = this.form.querySelector(`[name="${key}"]`);
            if (input) {
              input.value = data[key];
            }
          });
        }
      }

      handleSubmit(e) {
        e.preventDefault();
        
        const formData = new FormData(this.form);
        
        fetch(this.form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        }).then(response => {
          if (response.ok) {
            this.contentDiv.style.display = 'none';
            this.successDiv.classList.add('ai-show-{{ ai_gen_id }}');
            localStorage.removeItem('ai-quote-form-{{ ai_gen_id }}');
            
            setTimeout(() => {
              this.closeForm();
              setTimeout(() => {
                this.contentDiv.style.display = 'block';
                this.successDiv.classList.remove('ai-show-{{ ai_gen_id }}');
                this.currentStep = 1;
                this.updateStep();
                this.form.reset();
              }, 2000);
            }, 3000);
          }
        }).catch(error => {
          console.error('Form submission error:', error);
        });
      }
    }

    customElements.define('instant-quote-form-{{ ai_gen_id }}', InstantQuoteForm{{ ai_gen_id }});
  })();
</script>

