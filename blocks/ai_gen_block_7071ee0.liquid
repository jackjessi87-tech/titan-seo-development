{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-quote-form-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-quote-form-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    pointer-events: all;
  }

  .ai-quote-form-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
  }

  .ai-quote-form-container-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    right: 40px;
    transform: translate(0, -50%) translateX(30px);
    width: 100%;
    max-width: 420px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-quote-form-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-quote-form-container-{{ ai_gen_id }} {
    transform: translate(0, -50%) translateX(0);
  }

  .ai-quote-form-card-{{ ai_gen_id }} {
    background: {{ block.settings.form_background }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    padding: 32px;
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }

  .ai-quote-form-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    transition: opacity 0.3s ease;
    z-index: 10;
  }

  .ai-quote-form-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-quote-form-header-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-quote-form-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ai-quote-form-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    line-height: 1.4;
  }

  .ai-quote-form-progress-{{ ai_gen_id }} {
    height: 4px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    margin-bottom: 24px;
    overflow: hidden;
  }

  .ai-quote-form-progress-bar-{{ ai_gen_id }} {
    height: 100%;
    background: {{ block.settings.button_color }};
    transition: width 0.3s ease;
    border-radius: 2px;
  }

  .ai-quote-form-step-{{ ai_gen_id }} {
    display: none;
  }

  .ai-quote-form-step-{{ ai_gen_id }}.ai-active-{{ ai_gen_id }} {
    display: block;
    animation: ai-fade-in-{{ ai_gen_id }} 0.3s ease;
  }

  @keyframes ai-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-quote-form-label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 8px;
  }

  .ai-quote-form-input-{{ ai_gen_id }},
  .ai-quote-form-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    color: #000000;
    font-size: 15px;
    transition: all 0.3s ease;
    margin-bottom: 16px;
  }

  .ai-quote-form-input-{{ ai_gen_id }}:focus,
  .ai-quote-form-select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.button_color }};
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
  }

  .ai-quote-form-options-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }

  .ai-quote-form-option-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-quote-form-option-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .ai-quote-form-option-{{ ai_gen_id }}.ai-selected-{{ ai_gen_id }} {
    background: {{ block.settings.button_color }};
    border-color: {{ block.settings.button_color }};
    color: #ffffff;
  }

  .ai-quote-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 24px;
    background: linear-gradient(135deg, {{ block.settings.button_color }} 0%, {{ block.settings.button_hover_color }} 100%);
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .ai-quote-form-button-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(220, 38, 38, 0.4);
  }

  .ai-quote-form-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .ai-quote-form-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .ai-quote-form-back-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 24px;
    background: rgba(255, 255, 255, 0.2);
    color: {{ block.settings.text_color }};
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-quote-form-back-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .ai-quote-form-next-{{ ai_gen_id }} {
    flex: 2;
  }

  .ai-quote-form-trust-{{ ai_gen_id }} {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-quote-form-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 600;
  }

  .ai-quote-form-stars-{{ ai_gen_id }} {
    color: #fbbf24;
    font-size: 16px;
  }

  .ai-quote-form-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .ai-quote-form-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    color: {{ block.settings.text_color }};
    font-size: 12px;
  }

  .ai-quote-form-check-{{ ai_gen_id }} {
    color: #10b981;
    font-weight: 700;
  }

  .ai-quote-form-success-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 20px;
  }

  .ai-quote-form-success-{{ ai_gen_id }}.ai-show-{{ ai_gen_id }} {
    display: block;
  }

  .ai-quote-form-success-icon-{{ ai_gen_id }} {
    width: 64px;
    height: 64px;
    background: #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: #ffffff;
    font-size: 32px;
  }

  .ai-quote-form-success-title-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
  }

  .ai-quote-form-success-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.6;
  }

  .ai-quote-form-contact-{{ ai_gen_id }} {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-quote-form-phone-{{ ai_gen_id }},
  .ai-quote-form-whatsapp-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.2);
    color: {{ block.settings.text_color }};
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s ease;
    margin: 0 4px 8px 0;
  }

  .ai-quote-form-phone-{{ ai_gen_id }}:hover,
  .ai-quote-form-whatsapp-{{ ai_gen_id }}:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-quote-form-container-{{ ai_gen_id }} {
      right: 20px;
      left: 20px;
      max-width: none;
      transform: translate(0, -50%) translateY(30px);
    }

    .ai-quote-form-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-quote-form-container-{{ ai_gen_id }} {
      transform: translate(0, -50%) translateY(0);
    }

    .ai-quote-form-card-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-quote-form-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-quote-form-options-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-quote-form-features-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<instant-quote-form-{{ ai_gen_id }}
  class="ai-quote-form-{{ ai_gen_id }}"
  data-scroll-trigger="{{ block.settings.scroll_trigger }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-quote-form-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-quote-form-container-{{ ai_gen_id }}">
    <div class="ai-quote-form-card-{{ ai_gen_id }}">
      <button
        type="button"
        class="ai-quote-form-close-{{ ai_gen_id }}"
        aria-label="Close form"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="ai-quote-form-content-{{ ai_gen_id }}">
        <div class="ai-quote-form-header-{{ ai_gen_id }}">
          <h2 class="ai-quote-form-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          <p class="ai-quote-form-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        </div>

        <div class="ai-quote-form-progress-{{ ai_gen_id }}">
          <div class="ai-quote-form-progress-bar-{{ ai_gen_id }}" style="width: 12.5%;"></div>
        </div>

        {% form 'contact' %}
          <input type="hidden" name="contact[subject]" value="Instant Removalist Quote Request">
          
          <div class="ai-quote-form-step-{{ ai_gen_id }} ai-active-{{ ai_gen_id }}" data-step="1">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Pickup Suburb</label>
            <input
              type="text"
              name="contact[pickup_suburb]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="Enter pickup suburb"
              required
            >
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="2">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Delivery Suburb</label>
            <input
              type="text"
              name="contact[delivery_suburb]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="Enter delivery suburb"
              required
            >
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="3">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">What Are You Moving?</label>
            <input type="hidden" name="contact[moving_item]" class="ai-quote-form-moving-value-{{ ai_gen_id }}">
            <div class="ai-quote-form-options-{{ ai_gen_id }}">
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Sofa">Sofa</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Bed">Bed</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Mattress">Mattress</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Dining Table">Dining Table</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Marketplace Purchase">Marketplace Purchase</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Apartment Move">Apartment Move</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Multiple Items">Multiple Items</div>
            </div>
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="4">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Stairs or Lift?</label>
            <input type="hidden" name="contact[access_type]" class="ai-quote-form-access-value-{{ ai_gen_id }}">
            <div class="ai-quote-form-options-{{ ai_gen_id }}">
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Ground Floor">Ground Floor</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Lift Available">Lift Available</div>
              <div class="ai-quote-form-option-{{ ai_gen_id }}" data-value="Stairs">Stairs</div>
            </div>
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="5">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Preferred Date</label>
            <input
              type="text"
              name="contact[preferred_date]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="DD/MM/YYYY"
              required
            >
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="6">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Name</label>
            <input
              type="text"
              name="contact[name]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="Your name"
              required
            >
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="7">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Phone Number</label>
            <input
              type="tel"
              name="contact[phone]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="04XX XXX XXX"
              required
            >
          </div>

          <div class="ai-quote-form-step-{{ ai_gen_id }}" data-step="8">
            <label class="ai-quote-form-label-{{ ai_gen_id }}">Email Address</label>
            <input
              type="email"
              name="contact[email]"
              class="ai-quote-form-input-{{ ai_gen_id }}"
              placeholder="your@email.com"
              required
            >
          </div>

          <div class="ai-quote-form-nav-{{ ai_gen_id }}">
            <button
              type="button"
              class="ai-quote-form-back-{{ ai_gen_id }}"
              style="display: none;"
            >
              ← Back
            </button>
            <button
              type="button"
              class="ai-quote-form-next-{{ ai_gen_id }} ai-quote-form-button-{{ ai_gen_id }}"
            >
              Next →
            </button>
          </div>
        {% endform %}

        <div class="ai-quote-form-success-{{ ai_gen_id }}">
          <div class="ai-quote-form-success-icon-{{ ai_gen_id }}">✓</div>
          <h3 class="ai-quote-form-success-title-{{ ai_gen_id }}">Thank You!</h3>
          <p class="ai-quote-form-success-text-{{ ai_gen_id }}">
            Your quote request has been received.<br>
            Titan Express will contact you shortly with pricing and availability.
          </p>
        </div>

        <div class="ai-quote-form-trust-{{ ai_gen_id }}">
          <div class="ai-quote-form-rating-{{ ai_gen_id }}">
            <span class="ai-quote-form-stars-{{ ai_gen_id }}">★★★★★</span>
            <span>5 Star Service</span>
          </div>
          <div class="ai-quote-form-features-{{ ai_gen_id }}">
            <div class="ai-quote-form-feature-{{ ai_gen_id }}">
              <span class="ai-quote-form-check-{{ ai_gen_id }}">✓</span>
