<jobs-slider-{{ ai_gen_id }} class="ai-jobs-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if page.metafields.custom.recent_jobs.value %}
    <div class="ai-jobs-wrapper-{{ ai_gen_id }}">
      <div class="ai-jobs-track-{{ ai_gen_id }}" data-track>
        {% for job in page.metafields.custom.recent_jobs.value %}
          {% assign all_suburbs = '' %}
          {% if job.pickup_suburb and job.pickup_suburb != blank %}
            {% assign all_suburbs = all_suburbs | append: job.pickup_suburb %}
          {% endif %}
          {% if job.drop_off_suburb and job.drop_off_suburb != blank %}
            {% if all_suburbs != blank %}
              {% assign all_suburbs = all_suburbs | append: ', ' %}
            {% endif %}
            {% assign all_suburbs = all_suburbs | append: job.drop_off_suburb %}
          {% endif %}
          {% if job.related_suburbs and job.related_suburbs != blank %}
            {% if all_suburbs != blank %}
              {% assign all_suburbs = all_suburbs | append: ', ' %}
            {% endif %}
            {% assign all_suburbs = all_suburbs | append: job.related_suburbs %}
          {% endif %}

          <article class="ai-job-slide-{{ ai_gen_id }}" itemscope itemtype="https://schema.org/Service">
            <div class="ai-job-img-{{ ai_gen_id }}">
              {% if job.image %}
                <img
                  src="{{ job.image | image_url: width: 400 }}"
                  alt="{{ job.job_title | default: 'Delivery service' | escape }}"
                  loading="lazy"
                  width="400"
                  height="300"
                  itemprop="image"
                >
              {% else %}
                <div class="ai-job-img-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              
              {% if job.service_type %}
                <div class="ai-job-badge-{{ ai_gen_id }}" itemprop="serviceType">{{ job.service_type }}</div>
              {% endif %}
            </div>

            <div class="ai-job-body-{{ ai_gen_id }}">
              {% if job.job_title %}
                <h3 class="ai-job-title-{{ ai_gen_id }}" itemprop="name">{{ job.job_title }}</h3>
              {% endif %}
              
              {% if job.job_date %}
                <div class="ai-job-meta-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  <time datetime="{{ job.job_date | date: '%Y-%m-%d' }}">{{ job.job_date | date: "%d %b %Y" }}</time>
                </div>
              {% endif %}

              {% if job.pickup_suburb or job.drop_off_suburb %}
                <div class="ai-job-route-{{ ai_gen_id }}">
                  {% if job.pickup_suburb %}
                    <div class="ai-job-route-row-{{ ai_gen_id }}">
                      <span class="ai-job-route-icon-{{ ai_gen_id }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                          <circle cx="12" cy="10" r="3"/>
                        </svg>
                      </span>
                      <span class="ai-job-route-label-{{ ai_gen_id }}">From</span>
                      <span class="ai-job-route-value-{{ ai_gen_id }}">{{ job.pickup_suburb }}</span>
                    </div>
                  {% endif %}

                  {% if job.pickup_suburb and job.drop_off_suburb %}
                    <div class="ai-job-divider-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24">
                        <rect x="1" y="3" width="15" height="13"/>
                        <path d="M16 8h5l3 3v5h-2"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/>
                        <circle cx="18.5" cy="18.5" r="2.5"/>
                      </svg>
                    </div>
                  {% endif %}

                  {% if job.drop_off_suburb %}
                    <div class="ai-job-route-row-{{ ai_gen_id }}">
                      <span class="ai-job-route-icon-{{ ai_gen_id }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                          <circle cx="12" cy="10" r="3"/>
                        </svg>
                      </span>
                      <span class="ai-job-route-label-{{ ai_gen_id }}">To</span>
                      <span class="ai-job-route-value-{{ ai_gen_id }}">{{ job.drop_off_suburb }}</span>
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              <div class="ai-job-grid-{{ ai_gen_id }}">
                {% if job.item %}
                  <div class="ai-job-info-{{ ai_gen_id }}">
                    <div class="ai-job-info-label-{{ ai_gen_id }}">Item</div>
                    <div class="ai-job-info-value-{{ ai_gen_id }}">{{ job.item }}</div>
                  </div>
                {% endif %}

                {% if job.service_type %}
                  <div class="ai-job-info-{{ ai_gen_id }}">
                    <div class="ai-job-info-label-{{ ai_gen_id }}">Service</div>
                    <div class="ai-job-info-value-{{ ai_gen_id }}">{{ job.service_type }}</div>
                  </div>
                {% endif %}

                {% if job.rating %}
                  <div class="ai-job-info-{{ ai_gen_id }}">
                    <div class="ai-job-info-label-{{ ai_gen_id }}">Rating</div>
                    <div class="ai-job-rating-{{ ai_gen_id }}" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
                      <div class="ai-job-stars-{{ ai_gen_id }}">
                        {% assign rating_num = job.rating | times: 1.0 %}
                        {% assign full_stars = rating_num | floor %}
                        {% for i in (1..5) %}
                          {% if i <= full_stars %}
                            <svg viewBox="0 0 24 24">
                              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                          {% endif %}
                        {% endfor %}
                      </div>
                      <span class="ai-job-rating-num-{{ ai_gen_id }}">
                        <span itemprop="ratingValue">{{ job.rating }}</span>/<span itemprop="bestRating">5</span>
                      </span>
                      <meta itemprop="ratingCount" content="1">
                    </div>
                  </div>
                {% endif %}

                {% if job.job_date %}
                  <div class="ai-job-info-{{ ai_gen_id }}">
                    <div class="ai-job-info-label-{{ ai_gen_id }}">Date</div>
                    <div class="ai-job-info-value-{{ ai_gen_id }}">{{ job.job_date | date: "%d/%m/%y" }}</div>
                  </div>
                {% endif %}
              </div>

              {% if job.price_range %}
                <div class="ai-job-price-{{ ai_gen_id }}" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                  <div class="ai-job-price-label-{{ ai_gen_id }}">Price</div>
                  <div class="ai-job-price-value-{{ ai_gen_id }}" itemprop="price">{{ job.price_range }}</div>
                  <meta itemprop="priceCurrency" content="AUD">
                </div>
              {% endif %}

              {% if job.short_description %}
                <div class="ai-job-desc-{{ ai_gen_id }}" itemprop="description">
                  {{ job.short_description }}
                </div>
              {% endif %}

              {% if all_suburbs != blank %}
                <div class="ai-job-local-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <div class="ai-job-local-text-{{ ai_gen_id }}" itemprop="areaServed">
                    <span class="ai-job-local-strong-{{ ai_gen_id }}">Local</span> in {{ all_suburbs }}
                  </div>
                </div>
              {% endif %}

              <div class="ai-job-features-{{ ai_gen_id }}">
                <div class="ai-job-features-title-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  Professional
                </div>
                <div class="ai-job-features-list-{{ ai_gen_id }}">
                  <div class="ai-job-feature-{{ ai_gen_id }}">
                    <span class="ai-job-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    <span>Van</span>
                  </div>
                  <div class="ai-job-feature-{{ ai_gen_id }}">
                    <span class="ai-job-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    <span>Blankets</span>
                  </div>
                  <div class="ai-job-feature-{{ ai_gen_id }}">
                    <span class="ai-job-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    <span>Equipment</span>
                  </div>
                  <div class="ai-job-feature-{{ ai_gen_id }}">
                    <span class="ai-job-feature-icon-{{ ai_gen_id }}">
                      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    <span>Insured</span>
                  </div>
                </div>
              </div>

              <a
                href="#{{ block.settings.form_id }}"
                class="ai-job-cta-{{ ai_gen_id }}"
                data-cta-link
              >
                {{ block.settings.button_text }}
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    <div class="ai-jobs-dots-{{ ai_gen_id }}" data-dots></div>
  {% endif %}
</jobs-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class JobsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.isPaused = false;
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-jobs-wrapper-{{ ai_gen_id }}');
        this.track = this.querySelector('[data-track]');
        this.slides = this.querySelectorAll('.ai-job-slide-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('[data-dots]');
        
        if (!this.track || this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        
        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      createDots() {
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.className = 'ai-jobs-dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          if (index === 0) dot.classList.add('active');
          
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.stopAutoplay();
          });
          
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        const ctaLinks = this.querySelectorAll('[data-cta-link]');
        ctaLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            const href = link.getAttribute('href');
            if (href && href.startsWith('#')) {
              e.preventDefault();
              const target = document.getElementById(href.substring(1));
              if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            }
          });
        });

        this.wrapper.addEventListener('mouseenter', () => this.pauseAutoplay());
        this.wrapper.addEventListener('mouseleave', () => this.resumeAutoplay());
        this.wrapper.addEventListener('touchstart', () => this.pauseAutoplay());

        let touchStartX = 0;
        let touchEndX = 0;

        this.wrapper.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.wrapper.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const diff = startX - endX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.prevSlide();
          }
          this.stopAutoplay();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        const slideWidth = this.slides[0].offsetWidth;
        const gap = window.innerWidth >= 420 ? 12 : 10;
        const offset = -(slideWidth + gap) * index;
        
        this.track.style.transform = `translateX(${offset}px)`;
        
        this.updateDots();
      }

      nextSlide() {
        this.currentIndex = (this.currentIndex + 1) % this.slides.length;
        this.goToSlide(this.currentIndex);
      }

      prevSlide() {
        this.currentIndex = (this.currentIndex - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(this.currentIndex);
      }

      updateDots() {
        const dots = this.dotsContainer.querySelectorAll('.ai-jobs-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          if (!this.isPaused) {
            this.nextSlide();
          }
        }, {{ block.settings.autoplay_speed }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      pauseAutoplay() {
        this.isPaused = true;
      }

      resumeAutoplay() {
        this.isPaused = false;
      }
    }

    customElements.define('jobs-slider-{{ ai_gen_id }}', JobsSlider{{ ai_gen_id }});
  })();
</script>

