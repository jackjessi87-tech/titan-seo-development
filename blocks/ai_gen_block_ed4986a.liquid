{% doc %}
  @prompt
    Redesign the "Recent Delivery Jobs" cards to create a premium case-study style layout instead of simply displaying metaobject fields.
    
    Load all information dynamically from:
    
    page.metafields.custom.recent_jobs.value
    
    Do not hardcode any values.
    
    Hide any field that has no value.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    1. HERO IMAGE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Image
    
    Display a large featured image.
    
    Aspect ratio 16:9
    
    Rounded corners
    
    Lazy load
    
    Object-fit cover
    
    Generate ALT text dynamically.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    2. DELIVERY TITLE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Job Title
    
    Display as large bold heading.
    
    Example
    
    Fridge Delivery
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    3. DELIVERY ROUTE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Pickup Suburb
    
    Drop-off Suburb
    
    Display as a premium route timeline.
    
    📍 Pickup
    
    Mt Druitt
    
    ↓
    
    🚚 Titan Express
    
    ↓
    
    📍 Delivered
    
    Blacktown
    
    Show route inside a light background card.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    4. JOB INFORMATION
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Instead of black badges, create premium information cards.
    
    Display:
    
    📦 Item
    
    Example
    
    Fridge
    
    ━━━━━━━━
    
    🚚 Service
    
    Example
    
    Fridge Delivery
    
    ━━━━━━━━
    
    📅 Completed
    
    Example
    
    4 July 2026
    
    ━━━━━━━━
    
    ⭐ Customer Rating
    
    Convert numeric value to stars.
    
    Example
    
    ★★★★★
    
    5.0 out of 5
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    5. PRICE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Price Range
    
    Display inside a premium highlighted pricing card.
    
    Example
    
    Delivery Price
    
    $100–$120
    
    Do not use a black badge.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    6. DELIVERY SUMMARY
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Short Description
    
    Display as a highlighted paragraph.
    
    Example
    
    This fridge was collected safely from Mt Druitt and delivered the same day to Blacktown using our oversized furniture delivery van.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    7. RELATED SUBURBS
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Related Suburbs
    
    Display each suburb individually as modern location chips.
    
    Example
    
    Blacktown
    
    Quakers Hill
    
    Seven Hills
    
    Do not display all suburbs as one sentence.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    8. RELATED SERVICES
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load:
    
    Related Services
    
    Display each service as a clickable badge.
    
    Example
    
    Washing Machine Delivery
    
    Mattress Delivery
    
    Furniture Delivery
    
    Do not display them as one line of text.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    9. WHY CUSTOMERS CHOOSE US
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Always display:
    
    ✓ Oversized Van
    
    ✓ Furniture Blankets
    
    ✓ Professional Equipment
    
    ✓ Same Day Delivery
    
    ✓ Fully Insured
    
    ✓ Experienced Furniture Handlers
    
    Display inside a premium light coloured card.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    10. CTA
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Button
    
    Get Similar Delivery Quote
    
    Allow configurable Quote Form ID.
    
    Smooth scroll to Quote Form.
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    11. CARD STYLE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    White background
    
    18px border radius
    
    Soft shadow
    
    Modern typography
    
    Excellent spacing
    
    24px internal padding
    
    Glass effect
    
    Premium hover lift
    
    Image zoom
    
    Desktop
    
    3 cards
    
    Tablet
    
    2 cards
    
    Mobile
    
    Horizontal swipe carousel
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    12. FIELD MAPPING
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Load exactly these fields.
    
    Job Title
    
    → Main Heading
    
    Pickup Suburb
    
    → Pickup Location
    
    Drop-off Suburb
    
    → Delivery Location
    
    Item
    
    → Item Badge
    
    Service Type
    
    → Service Badge
    
    Short Description
    
    → Delivery Summary
    
    Image
    
    → Hero Image
    
    Job Date
    
    → Completion Date
    
    Rating
    
    → Customer Rating
    
    Related Suburbs
    
    → Location Chips
    
    Related Services
    
    → Service Chips
    
    Price Range
    
    → Pricing Card
    
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    13. PERFORMANCE
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    
    Use Shopify Liquid only.
    
    Use:
    
    page.metafields.custom.recent_jobs.value
    
    Loop through all selected jobs.
    
    No hardcoded content.
    
    No external libraries.
    
    Vanilla JavaScript.
    
