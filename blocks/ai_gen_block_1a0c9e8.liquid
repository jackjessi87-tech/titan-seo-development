{% doc %}
  @prompt
    Removals ServiceCards Wit Caption Tags And Information   Single Item Delivery   Small One Bedroom Move for Removalist Business small Moving Sevices 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-removals-services-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-removals-services__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-removals-services__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-removals-services__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-removals-service-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-removals-service-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-removals-service-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-removals-service-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-removals-service-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-removals-service-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-removals-service-card__tag-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.tag_border_radius }}px;
    font-size: {{ block.settings.tag_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-removals-service-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-removals-service-card__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 700;
  }

  .ai-removals-service-card__description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_spacing }}px;
  }

  .ai-removals-service-card__info-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: {{ block.settings.info_spacing }}px;
  }

  .ai-removals-service-card__info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.info_color }};
    font-size: {{ block.settings.info_size }}px;
  }

  .ai-removals-service-card__info-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .ai-removals-service-card__price-{{ ai_gen_id }} {
    color: {{ block.settings.price_color }};
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    margin-bottom: {{ block.settings.price_spacing }}px;
  }

  .ai-removals-service-card__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    text-align: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-removals-service-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 989px) {
    .ai-removals-services__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-removals-services__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-removals-services__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-removals-service-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<removals-services-{{ ai_gen_id }} class="ai-removals-services-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-removals-services__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-removals-services__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-removals-services__grid-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign service_enabled_key = 'service_' | append: i | append: '_enabled'
          assign service_image_key = 'service_' | append: i | append: '_image'
          assign service_tag_key = 'service_' | append: i | append: '_tag'
          assign service_title_key = 'service_' | append: i | append: '_title'
          assign service_description_key = 'service_' | append: i | append: '_description'
          assign service_duration_key = 'service_' | append: i | append: '_duration'
          assign service_distance_key = 'service_' | append: i | append: '_distance'
          assign service_price_key = 'service_' | append: i | append: '_price'
          assign service_link_key = 'service_' | append: i | append: '_link'

          assign service_enabled = block.settings[service_enabled_key]
          assign service_image = block.settings[service_image_key]
          assign service_tag = block.settings[service_tag_key]
          assign service_title = block.settings[service_title_key]
          assign service_description = block.settings[service_description_key]
          assign service_duration = block.settings[service_duration_key]
          assign service_distance = block.settings[service_distance_key]
          assign service_price = block.settings[service_price_key]
          assign service_link = block.settings[service_link_key]
        %}

        {% if service_enabled %}
          <div class="ai-removals-service-card-{{ ai_gen_id }}">
            <div class="ai-removals-service-card__image-wrapper-{{ ai_gen_id }}">
              {% if service_image %}
                <img
                  src="{{ service_image | image_url: width: 800 }}"
                  alt="{{ service_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="533"
                  class="ai-removals-service-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-removals-service-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if service_tag != blank %}
                <div class="ai-removals-service-card__tag-{{ ai_gen_id }}">
                  {{ service_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-removals-service-card__content-{{ ai_gen_id }}">
              {% if service_title != blank %}
                <h3 class="ai-removals-service-card__title-{{ ai_gen_id }}">{{ service_title }}</h3>
              {% endif %}

              {% if service_description != blank %}
                <p class="ai-removals-service-card__description-{{ ai_gen_id }}">{{ service_description }}</p>
              {% endif %}

              {% if service_duration != blank or service_distance != blank %}
                <div class="ai-removals-service-card__info-{{ ai_gen_id }}">
                  {% if service_duration != blank %}
                    <div class="ai-removals-service-card__info-item-{{ ai_gen_id }}">
                      <svg class="ai-removals-service-card__info-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      <span>{{ service_duration }}</span>
                    </div>
                  {% endif %}

                  {% if service_distance != blank %}
                    <div class="ai-removals-service-card__info-item-{{ ai_gen_id }}">
                      <svg class="ai-removals-service-card__info-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="2" x2="12" y2="22"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                      </svg>
                      <span>{{ service_distance }}</span>
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if service_price != blank %}
                <div class="ai-removals-service-card__price-{{ ai_gen_id }}">{{ service_price }}</div>
              {% endif %}

              {% if service_link != blank %}
                <a href="{{ service_link }}" class="ai-removals-service-card__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</removals-services-{{ ai_gen_id }}>

<script>
  (function() {
    class RemovalsServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('removals-services-{{ ai_gen_id }}', RemovalsServices{{ ai_gen_id }});
  })();
</script>

