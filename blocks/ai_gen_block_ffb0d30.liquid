<section class="ai-service-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }} aria-label="Service hero">
  <div class="ai-service-hero-container-{{ ai_gen_id }}">
    <header class="ai-service-hero-content-{{ ai_gen_id }}">
      {% if page.metafields.custom.badge_text.value != blank %}
        <div class="ai-service-hero-badge-{{ ai_gen_id }}" role="status">
          <svg class="ai-service-hero-badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {{ page.metafields.custom.badge_text.value }}
        </div>
      {% endif %}

      <h1 class="ai-service-hero-heading-{{ ai_gen_id }}">
        {{ page.title | default: 'Premium Furniture Removalist Services' }}
      </h1>

      {% if page.metafields.custom.hero_subheading != blank %}
        <div class="ai-service-hero-subheading-{{ ai_gen_id }}">
          {{ page.metafields.custom.hero_subheading | metafield_tag }}
        </div>
      {% endif %}

      {% if page.metafields.custom.service_area != blank %}
        <div class="ai-service-hero-service-area-{{ ai_gen_id }}">
          {{ page.metafields.custom.service_area | metafield_tag }}
        </div>
      {% endif %}

      {% if page.metafields.custom.google_rating.value != blank and page.metafields.custom.google_review_count.value != blank %}
        <div class="ai-service-hero-google-card-{{ ai_gen_id }}">
          <svg class="ai-service-hero-google-logo-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-label="Google">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div class="ai-service-hero-rating-info-{{ ai_gen_id }}">
            <div class="ai-service-hero-stars-{{ ai_gen_id }}" role="img" aria-label="{{ page.metafields.custom.google_rating.value }} out of 5 stars">
              {% assign rating = page.metafields.custom.google_rating.value | times: 1.0 %}
              {% for i in (1..5) %}
                <svg class="ai-service-hero-star-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="{% if i <= rating %}#FFC107{% else %}#E0E0E0{% endif %}" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
            <div class="ai-service-hero-rating-text-{{ ai_gen_id }}">
              {{ page.metafields.custom.google_rating.value }} Google Rating · {{ page.metafields.custom.google_review_count.value }} Reviews
            </div>
            {% if page.metafields.custom.google_review_url.value != blank %}
              <a href="{{ page.metafields.custom.google_review_url.value }}" target="_blank" rel="noopener noreferrer" class="ai-service-hero-review-link-{{ ai_gen_id }}">
                Read Google Reviews
                <svg class="ai-service-hero-review-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <nav class="ai-service-hero-buttons-{{ ai_gen_id }}" aria-label="Call to action">
        {% if page.metafields.custom.primary_cta_text.value != blank and page.metafields.custom.primary_cta_link.value != blank %}
          <a href="{{ page.metafields.custom.primary_cta_link.value }}" class="ai-service-hero-button-{{ ai_gen_id }} ai-service-hero-button-primary-{{ ai_gen_id }}">
            <span>{{ page.metafields.custom.primary_cta_text.value }}</span>
            <svg class="ai-service-hero-button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        {% endif %}

        {% if page.metafields.custom.secondary_cta_text.value != blank and page.metafields.custom.secondary_cta_link.value != blank %}
          <a href="{{ page.metafields.custom.secondary_cta_link.value }}" class="ai-service-hero-button-{{ ai_gen_id }} ai-service-hero-button-secondary-{{ ai_gen_id }}">
            <span>{{ page.metafields.custom.secondary_cta_text.value }}</span>
            <svg class="ai-service-hero-button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </a>
        {% endif %}
      </nav>

      {% if page.metafields.custom.target_keywords.value != blank %}
        <div class="ai-service-hero-seo-keywords-{{ ai_gen_id }}">
          {{ page.metafields.custom.target_keywords.value }}
        </div>
      {% endif %}
    </header>

    <div class="ai-service-hero-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-service-hero-dynamic-headline-{{ ai_gen_id }}">
        <h2 class="ai-service-hero-dynamic-h2-{{ ai_gen_id }}">
          {% if target_suburb != blank %}
            Need Furniture Delivered in {{ target_suburb }}?
          {% else %}
            Need Furniture Delivered Near You?
          {% endif %}
        </h2>
        <p class="ai-service-hero-typing-line-{{ ai_gen_id }}">
          <span class="ai-service-hero-typing-text-{{ ai_gen_id }}" data-typing-text="{% if target_suburb != blank %}Book a Man and Van in {{ target_suburb }}{% else %}Book a Man and Van Near You{% endif %}"></span>
        </p>
      </div>

      <figure class="ai-service-hero-figure-{{ ai_gen_id }}">
        {% if page.metafields.custom.hero_image != blank %}
          <img
            src="{{ page.metafields.custom.hero_image | image_url: width: 1200 }}"
            srcset="{{ page.metafields.custom.hero_image | image_url: width: 600 }} 600w, {{ page.metafields.custom.hero_image | image_url: width: 900 }} 900w, {{ page.metafields.custom.hero_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ page.metafields.custom.hero_image_alt.value | default: page.title | escape }}"
            {% if page.metafields.custom.hero_image_title.value != blank %}
              title="{{ page.metafields.custom.hero_image_title.value | escape }}"
            {% endif %}
            class="ai-service-hero-image-{{ ai_gen_id }}"
            loading="eager"
            fetchpriority="high"
            width="1200"
            height="900"
          >
          {% if page.metafields.custom.hero_image_caption.value != blank %}
            <figcaption class="ai-service-hero-caption-{{ ai_gen_id }}">
              {{ page.metafields.custom.hero_image_caption.value }}
            </figcaption>
          {% endif %}
        {% else %}
          <div class="ai-service-hero-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-service-hero-empty-{{ ai_gen_id }}">
              Add hero image
            </div>
          </div>
        {% endif %}

        {% if page.metafields.custom.overlay_highlights.value != blank %}
          <div class="ai-service-hero-overlay-{{ ai_gen_id }}" aria-hidden="true">
            {% for highlight in page.metafields.custom.overlay_highlights.value limit: 8 %}
              <div class="ai-service-hero-overlay-card-{{ ai_gen_id }}">
                <svg class="ai-service-hero-overlay-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="ai-service-hero-overlay-text-{{ ai_gen_id }}">{{ highlight }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </figure>
    </div>
  </div>

  {% if page.metafields.custom.trust_points.value != blank %}
    <div class="ai-service-hero-trust-bar-{{ ai_gen_id }}">
      {% for point in page.metafields.custom.trust_points.value %}
        <div class="ai-service-hero-trust-item-{{ ai_gen_id }}">
          <svg class="ai-service-hero-trust-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="ai-service-hero-trust-text-{{ ai_gen_id }}">{{ point }}</span>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>

<script>
  (function() {
    const typingElement = document.querySelector('.ai-service-hero-typing-text-{{ ai_gen_id }}');
    if (!typingElement) return;

    const text = typingElement.getAttribute('data-typing-text');
    if (!text) return;

    let index = 0;
    typingElement.textContent = '';

    function type() {
      if (index < text.length) {
        typingElement.textContent += text.charAt(index);
        index++;
        setTimeout(type, 50);
      }
    }

    setTimeout(type, 500);
  })();
</script>

{% if block.settings.enable_schema %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "name": {{ page.title | json }},
        "url": "{{ shop.url }}{{ page.url }}"
        {% if page.metafields.custom.hero_subheading != blank %}
          {% assign description = page.metafields.custom.hero_subheading | metafield_text | strip_html | strip %}
          {% if description != blank %}
            ,"description": {{ description | json }}
          {% endif %}
        {% endif %}
        {% if page.metafields.custom.hero_image != blank %}
          ,"image": {
            "@type": "ImageObject",
            "url": "{{ page.metafields.custom.hero_image | image_url: width: 1200 }}",
            "width": 1200,
            "height": 900
            {% if page.metafields.custom.hero_image_alt.value != blank %}
              ,"name": {{ page.metafields.custom.hero_image_alt.value | json }}
            {% endif %}
            {% if page.metafields.custom.hero_image_caption.value != blank %}
              ,"caption": {{ page.metafields.custom.hero_image_caption.value | json }}
            {% endif %}
          }
        {% endif %}
      }
      {% if schema_service != blank %}
        ,{
          "@type": "Service",
          "serviceType": {{ schema_service | json }},
          "provider": {
            "@type": "LocalBusiness",
            "name": {{ shop.name | json }},
            "url": "{{ shop.url }}"
            {% if page.metafields.custom.phone_number.value != blank %}
              ,"telephone": {{ page.metafields.custom.phone_number.value | json }}
            {% endif %}
            {% if page.metafields.custom.google_rating.value != blank and page.metafields.custom.google_review_count.value != blank %}
              ,"aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": {{ page.metafields.custom.google_rating.value | json }},
                "reviewCount": {{ page.metafields.custom.google_review_count.value | json }}
              }
            {% endif %}
            {% if page.metafields.custom.hero_image != blank %}
              ,"image": "{{ page.metafields.custom.hero_image | image_url: width: 1200 }}"
            {% endif %}
          }
          {% if schema_area != blank %}
            ,"areaServed": {
              "@type": "City",
              "name": {{ schema_area | json }}
            }
          {% endif %}
          {% if schema_price != blank %}
            ,"priceRange": {{ schema_price | json }}
          {% endif %}
        }
      {% endif %}
      {% if page.metafields.custom.phone_number.value != blank %}
        ,{
          "@type": "LocalBusiness",
          "name": {{ shop.name | json }},
          "url": "{{ shop.url }}",
          "telephone": {{ page.metafields.custom.phone_number.value | json }},
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": {{ page.metafields.custom.phone_number.value | json }},
            "contactType": "Customer Service"
          }
          {% if page.metafields.custom.google_rating.value != blank and page.metafields.custom.google_review_count.value != blank %}
            ,"aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": {{ page.metafields.custom.google_rating.value | json }},
              "reviewCount": {{ page.metafields.custom.google_review_count.value | json }}
            }
          {% endif %}
        }
      {% endif %}
      ,{
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "{{ shop.url }}"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }},
            "item": "{{ shop.url }}{{ page.url }}"
          }
        ]
      }
    ]
  }
  </script>
{% endif %}

