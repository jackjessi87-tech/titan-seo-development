  .ai-service-hero-overlay-card-{{ ai_gen_id }}:nth-child(5),
  .ai-service-hero-overlay-card-{{ ai_gen_id }}:nth-child(6),
  .ai-service-hero-overlay-card-{{ ai_gen_id }}:nth-child(7),
