{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recent-jobs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    padding: {{ block.settings.section_padding }}px 16px;
    position: relative;
    overflow: hidden;
  }

  .ai-recent-jobs-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 300px;
    height: 300px;
    background: {{ block.settings.shape_color }};
    border-radius: 50%;
    opacity: 0.1;
    z-index: 0;
  }

  .ai-recent-jobs-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 250px;
    height: 250px;
    background: {{ block.settings.shape_color }};
    border-radius: 50%;
    opacity: 0.08;
    z-index: 0;
  }

  .ai-recent-jobs-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-recent-jobs-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-recent-jobs-cards-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-recent-jobs-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    border-left: {{ block.settings.accent_border_width }}px solid {{ block.settings.accent_color }};
    position: relative;
    width: {{ block.settings.card_width }}%;
    max-width: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-recent-jobs-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
  }

  .ai-recent-jobs-route-{{ ai_gen_id }} {
    font-size: {{ block.settings.route_font_size }}px;
    color: {{ block.settings.route_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
    position: relative;
    display: inline-block;
    background: linear-gradient(90deg, {{ block.settings.route_color }} 0%, {{ block.settings.route_shine_color }} 50%, {{ block.settings.route_color }} 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ai-recent-jobs-bottom-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-recent-jobs-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: #f5f5f5;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-recent-jobs-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recent-jobs-badge-wrapper-{{ ai_gen_id }} {
    flex-grow: 1;
    min-width: 0;
  }

  .ai-recent-jobs-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
  }

  .ai-recent-jobs-cta-{{ ai_gen_id }} {
    margin-top: {{ block.settings.cta_spacing }}px;
    text-align: center;
  }

  .ai-recent-jobs-cta-link-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    padding: {{ block.settings.cta_padding }}px 24px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
  }

  .ai-recent-jobs-cta-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(220, 38, 38, 0.4);
  }

  @media screen and (min-width: 768px) {
    .ai-recent-jobs-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<section class="ai-recent-jobs-{{ ai_gen_id }}" {{ block.shopify_attributes }} aria-labelledby="ai-recent-jobs-heading-{{ ai_gen_id }}">
  <div class="ai-recent-jobs-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 id="ai-recent-jobs-heading-{{ ai_gen_id }}" class="ai-recent-jobs-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <ul class="ai-recent-jobs-cards-{{ ai_gen_id }}" role="list">
      {% for i in (1..8) %}
        {% liquid
          assign job_enabled_key = 'job_' | append: i | append: '_enabled'
          assign job_image_key = 'job_' | append: i | append: '_image'
          assign job_type_key = 'job_' | append: i | append: '_type'
          assign job_route_key = 'job_' | append: i | append: '_route'

          assign job_enabled = block.settings[job_enabled_key]
          assign job_image = block.settings[job_image_key]
          assign job_type = block.settings[job_type_key]
          assign job_route = block.settings[job_route_key]
        %}

        {% if job_enabled %}
          <li class="ai-recent-jobs-card-{{ ai_gen_id }}" itemscope itemtype="https://schema.org/Service">
            {% if job_route != blank %}
              <p class="ai-recent-jobs-route-{{ ai_gen_id }}" itemprop="areaServed">{{ job_route }}</p>
            {% endif %}
            
            <div class="ai-recent-jobs-bottom-{{ ai_gen_id }}">
              <div class="ai-recent-jobs-image-{{ ai_gen_id }}">
                {% if job_image %}
                  <img
                    src="{{ job_image | image_url: width: 300 }}"
                    alt="{{ job_type | escape }} delivery service from {{ job_route | escape }}"
                    loading="lazy"
                    width="300"
                    height="300"
                    itemprop="image"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="ai-recent-jobs-badge-wrapper-{{ ai_gen_id }}">
                {% if job_type != blank %}
                  <span class="ai-recent-jobs-badge-{{ ai_gen_id }}" itemprop="serviceType">{{ job_type }}</span>
                {% endif %}
              </div>
            </div>
          </li>
        {% endif %}
      {% endfor %}
    </ul>

    {% if block.settings.show_cta %}
      <div class="ai-recent-jobs-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_link }}" class="ai-recent-jobs-cta-link-{{ ai_gen_id }}" aria-label="{{ block.settings.cta_text | escape }} - Get instant delivery quote">
          {{ block.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

