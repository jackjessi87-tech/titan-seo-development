{% doc %}
  @prompt
    Create a Section Service card For Furntire Collection From Store Also show a Preview Photo next to the Text Make it a Service card also show a get quote button which takes scrollls ups to exisitign wuote form on website Scroll smoothly to #quote-form-22, whend someon click get quote redirect smoothly #template--21908510408809__17815179558092b9ce__ai_gen_block_c16df3d_kthrFG, get quote button redirects to 21908510408809__17815179558092b9ce__ai_gen_block_c16df3d_kthrFG
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-service-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-service-card-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-service-card-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
  }

  .ai-service-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-service-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-service-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-service-card-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-service-card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-service-card-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-family: var(--font-heading-family);
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-service-card-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-service-card-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-service-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-service-card-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-service-card-image-wrapper-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
    }

    .ai-service-card-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-service-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<service-card-{{ ai_gen_id }} class="ai-service-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-service-card-container-{{ ai_gen_id }}">
    <div class="ai-service-card-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.service_image %}
        <img
          src="{{ block.settings.service_image | image_url: width: 800 }}"
          alt="{{ block.settings.service_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.service_image.width }}"
          height="{{ block.settings.service_image.height }}"
          class="ai-service-card-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-service-card-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
          <div class="ai-service-card-empty-state-{{ ai_gen_id }}">
            Next, add a service image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-service-card-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h3 class="ai-service-card-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-service-card-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      <a
        href="#template--21908510408809__17815179558092b9ce__ai_gen_block_c16df3d_kthrFG"
        class="ai-service-card-button-{{ ai_gen_id }}"
        data-scroll-target="template--21908510408809__17815179558092b9ce__ai_gen_block_c16df3d_kthrFG"
      >
        {{ block.settings.button_text }}
      </a>
    </div>
  </div>
</service-card-{{ ai_gen_id }}>

<script>
  (function() {
    class ServiceCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('.ai-service-card-button-{{ ai_gen_id }}');
        if (this.button) {
          this.button.addEventListener('click', this.handleClick.bind(this));
        }
      }

      handleClick(event) {
        event.preventDefault();
        const targetId = this.button.getAttribute('data-scroll-target');
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      }

      disconnectedCallback() {
        if (this.button) {
          this.button.removeEventListener('click', this.handleClick);
        }
      }
    }

    customElements.define('service-card-{{ ai_gen_id }}', ServiceCard{{ ai_gen_id }});
  })();
</script>

