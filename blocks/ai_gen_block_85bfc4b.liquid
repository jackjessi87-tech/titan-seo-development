    },
    {
      "type": "header",
      "content": "Category badges"
    },
    {
      "type": "checkbox",
      "id": "show_category_badges",
      "label": "Show category badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Dynamic FAQ"
    }
  ]
}
{% endschema %}