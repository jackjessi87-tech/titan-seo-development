{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-floating-card-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    bottom: {{ block.settings.bottom_position }}px;
    right: {{ block.settings.right_position }}px;
    z-index: 999;
    width: {{ block.settings.card_width }}px;
    max-width: 90vw;
  }

  .ai-floating-card-container-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    -webkit-backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-floating-card-container-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y | plus: 4 }}px {{ block.settings.shadow_blur | plus: 8 }}px {{ block.settings.shadow_color }};
  }

  .ai-floating-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-floating-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-floating-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-floating-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-floating-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ai-floating-card-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0 0 16px 0;
    line-height: 1.4;
  }

  .ai-floating-card-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-floating-card-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .ai-floating-card-btn-quote-{{ ai_gen_id }} {
    background: {{ block.settings.quote_button_bg }};
    color: {{ block.settings.quote_button_text }};
  }

  .ai-floating-card-btn-quote-{{ ai_gen_id }}:hover {
    background: {{ block.settings.quote_button_hover }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px {{ block.settings.quote_button_bg }}66;
  }

  .ai-floating-card-btn-call-{{ ai_gen_id }} {
    background: {{ block.settings.call_button_bg }};
    color: {{ block.settings.call_button_text }};
  }

  .ai-floating-card-btn-call-{{ ai_gen_id }}:hover {
    background: {{ block.settings.call_button_hover }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px {{ block.settings.call_button_bg }}66;
  }

  .ai-floating-card-close-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    right: 8px;
    background: {{ block.settings.close_button_bg }};
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.close_button_color }};
    opacity: 0.9;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .ai-floating-card-close-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .ai-floating-card-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .ai-floating-card-{{ ai_gen_id }} {
      bottom: {{ block.settings.mobile_bottom }}px;
      right: {{ block.settings.mobile_right }}px;
      left: {{ block.settings.mobile_right }}px;
      width: auto;
    }

    .ai-floating-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-floating-card-image-{{ ai_gen_id }},
    .ai-floating-card-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_image_height }}px;
    }
  }
{% endstyle %}

<floating-card-{{ ai_gen_id }}
  class="ai-floating-card-{{ ai_gen_id }}"
  data-target-form="{{ block.settings.target_form_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-floating-card-container-{{ ai_gen_id }}">
    {% if block.settings.show_close_button %}
      <button
        class="ai-floating-card-close-{{ ai_gen_id }}"
        aria-label="Close card"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.card_image %}
      <img
        src="{{ block.settings.card_image | image_url: width: 1000 }}"
        alt="{{ block.settings.card_image.alt | escape }}"
        class="ai-floating-card-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.card_image.width }}"
        height="{{ block.settings.image_height }}"
      >
    {% else %}
      <div class="ai-floating-card-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}

    <div class="ai-floating-card-content-{{ ai_gen_id }}">
      {% if block.settings.card_title != blank %}
        <h3 class="ai-floating-card-title-{{ ai_gen_id }}">{{ block.settings.card_title }}</h3>
      {% endif %}

      {% if block.settings.card_subtitle != blank %}
        <p class="ai-floating-card-subtitle-{{ ai_gen_id }}">{{ block.settings.card_subtitle }}</p>
      {% endif %}

      <div class="ai-floating-card-buttons-{{ ai_gen_id }}">
        <button
          class="ai-floating-card-btn-{{ ai_gen_id }} ai-floating-card-btn-quote-{{ ai_gen_id }}"
          data-action="open-form"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          {{ block.settings.quote_btn_text }}
        </button>

        <a
          href="tel:{{ block.settings.phone_number }}"
          class="ai-floating-card-btn-{{ ai_gen_id }} ai-floating-card-btn-call-{{ ai_gen_id }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          {{ block.settings.call_btn_text }}
        </a>
      </div>
    </div>
  </div>
</floating-card-{{ ai_gen_id }}>

<script>
  (function() {
    class FloatingCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.quoteBtn = this.querySelector('[data-action="open-form"]');
        this.closeBtn = this.querySelector('.ai-floating-card-close-{{ ai_gen_id }}');
        this.targetFormId = this.dataset.targetForm;

        this.setupEventListeners();
        this.checkDismissed();
      }

      setupEventListeners() {
        if (this.quoteBtn) {
          this.quoteBtn.addEventListener('click', () => this.openForm());
        }

        if (this.closeBtn) {
          this.closeBtn.addEventListener('click', () => this.dismissCard());
        }
      }

      openForm() {
        if (this.targetFormId) {
          const targetForm = document.querySelector(this.targetFormId);
          if (targetForm) {
            targetForm.classList.add('visible');
            targetForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        } else {
          const quoteForm = document.querySelector('[class*="ai-quote-form-"]');
          if (quoteForm) {
            quoteForm.classList.add('visible');
          }
        }
      }

      dismissCard() {
        this.classList.add('hidden');
        localStorage.setItem('floatingCard{{ ai_gen_id }}Dismissed', 'true');
      }

      checkDismissed() {
        const dismissed = localStorage.getItem('floatingCard{{ ai_gen_id }}Dismissed');
        if (dismissed === 'true') {
          this.classList.add('hidden');
        }
      }
    }

    customElements.define('floating-card-{{ ai_gen_id }}', FloatingCard{{ ai_gen_id }});
  })();
</script>

