{% doc %}
  @prompt
    Build Section 3 directly below the Services Section.
    
    SECTION GOAL
    
    Build trust, reduce customer hesitation, and clearly explain why customers should choose Titan Express.
    
    This section should increase conversion rates and reinforce Google Ads landing page quality.
    
    SECTION TITLE
    
    Why Choose Titan Express?
    
    SUBHEADING
    
    Professional furniture moving and delivery services trusted by Sydney customers for reliability, care and fast response times.
    
    LAYOUT
    
    Create a modern premium trust section.
    
    Desktop:
    4 cards per row
    
    Tablet:
    2 cards per row
    
    Mobile:
    1 card per row
    
    Each card should feature:
    
    • Advanced SVG icon
    • Hover animation
    • Glassmorphism effects
    • Modern shadows
    • Smooth micro-interactions
    • Premium service-business styling
    
    TRUST CARDS
    
    Oversized Long Wheelbase Van
    
    Description:
    More furniture moved in one trip, saving time and reducing costs.
    
    Icon:
    Large delivery van SVG
    
    ---
    
    Professional Furniture Handling
    
    Description:
    Furniture is handled carefully using proven moving techniques.
    
    Icon:
    Furniture protection SVG
    
    ---
    
    Blankets, Straps & Trolley
    
    Description:
    Professional moving equipment helps protect items during transport.
    
    Icon:
    Trolley and moving equipment SVG
    
    ---
    
    Same Day Availability
    
    Description:
    Need urgent delivery today? Same-day service may be available.
    
    Icon:
    Clock and route SVG
    
    ---
    
    Sydney Wide Coverage
    
    Description:
    Covering Sydney CBD, Western Sydney, Inner West, Northern Beaches and surrounding suburbs.
    
    Icon:
    Sydney map SVG
    
    ---
    
    Marketplace Pickup Specialists
    
    Description:
    Experienced with Facebook Marketplace, Gumtree and private seller collections.
    
    Icon:
    Package pickup SVG
    
    ---
    
    Affordable Pricing
    
    Description:
    Flexible options including one-man-and-van or two-person moving teams.
    
    Icon:
    Savings SVG
    
    ---
    
    Fast Quote Response
    
    Description:
    Quick responses and transparent pricing without complicated booking processes.
    
    Icon:
    Chat and phone SVG
    
    STATISTICS SECTION
    
    Add animated counters:
    
    1000+
    Furniture Deliveries
    
    500+
    Happy Customers
    
    Sydney Wide
    Service Area
    
    Same Day
    Availability
    
    ANIMATION REQUIREMENTS
    
    • Number counters animate when visible
    • Cards lift slightly on hover
    • SVG icons animate subtly
    • Smooth fade-in effects while scrolling
    • Interactive glow effect on hover
    
    VISUAL STYLE
    
    Premium removalist company
    
    Colours:
    White
    Black
    Gold
    Yellow
    Blue trust accents
    
    BACKGROUND
    
    Use subtle route-line SVG graphics and location markers.
    
    Keep the section clean, professional and conversion-focused.
    
    GOOGLE ADS LANDING PAGE GOAL
    
    This section should answer:
    
    Why Titan Express?
    
    Why trust us?
    
    Why call now?
    
    OUTPUT
    
    Generate complete Shopify-compatible HTML, CSS and JavaScript.
    
    Use class names beginning with:
    
    titan-trust-
    
    The final result should feel premium, trustworthy, modern and highly professional.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .titan-trust-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  .titan-trust-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: {{ block.settings.background_pattern_opacity | divided_by: 100.0 }};
    pointer-events: none;
    z-index: 0;
  }

  .titan-trust-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .titan-trust-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .titan-trust-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .titan-trust-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .titan-trust-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.stats_spacing }}px;
  }

  .titan-trust-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid {{ block.settings.card_border_color }};
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px {{ block.settings.card_shadow_color }};
  }

  .titan-trust-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, {{ block.settings.card_glow_color }} 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .titan-trust-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px {{ block.settings.card_hover_shadow_color }};
  }

  .titan-trust-card-{{ ai_gen_id }}:hover::before {
    opacity: {{ block.settings.card_glow_opacity | divided_by: 100.0 }};
  }

  .titan-trust-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s ease;
  }

  .titan-trust-card-{{ ai_gen_id }}:hover .titan-trust-icon-wrapper-{{ ai_gen_id }} {
    transform: scale(1.1) rotate(5deg);
  }

  .titan-trust-icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .titan-trust-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    text-align: center;
    line-height: 1.3;
  }

  .titan-trust-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    text-align: center;
    line-height: 1.5;
    margin: 0;
  }

  .titan-trust-stats-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    padding: {{ block.settings.stats_padding }}px;
    background: {{ block.settings.stats_background }};
    border-radius: {{ block.settings.stats_border_radius }}px;
    border: 1px solid {{ block.settings.stats_border_color }};
  }

  .titan-trust-stat-{{ ai_gen_id }} {
    text-align: center;
  }

  .titan-trust-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.stat_number_color }};
    margin: 0 0 8px;
    line-height: 1;
  }

  .titan-trust-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_size }}px;
    color: {{ block.settings.stat_label_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 989px) {
    .titan-trust-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .titan-trust-stats-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .titan-trust-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .titan-trust-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .titan-trust-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .titan-trust-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .titan-trust-stats-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: {{ block.settings.stats_padding | times: 0.7 }}px;
    }

    .titan-trust-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.6);
    }

    .titan-trust-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

