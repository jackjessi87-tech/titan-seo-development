{%- doc -%}
  Process steps block. Renders an H2 plus a vertical list of numbered steps.
  Each step is a nested _process-step-item block with heading and description.
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
%}

<div
  class="process-steps process-steps--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <div class="process-steps__inner">
    {%- if block_settings.heading != blank -%}
      {{ block_settings.heading }}
    {%- endif -%}
    
    <div class="process-steps__list">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .process-steps__inner {
    max-width: var(--normal-content-width, 720px);
    margin-inline: auto;
    padding-inline: var(--padding-md, 16px);
  }

  .process-steps__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-lg, 24px);
    margin-top: var(--margin-lg, 20px);
    counter-reset: process-step;
  }

  .process-steps__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--gap-md, 16px);
    align-items: flex-start;
  }

  .process-steps__number {
    counter-increment: process-step;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-primary);
    color: white;
    border-radius: 50%;
    font-weight: var(--font-weight-bold, 700);
    flex-shrink: 0;
  }

  .process-steps__number::before {
    content: counter(process-step);
  }

  .process-steps__heading {
    margin-bottom: var(--margin-sm, 12px);
  }

  .process-steps__text {
    font-size: var(--font-paragraph-small--size, 0.875rem);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Process steps",
  "tag": null,
  "blocks": [
    { "type": "_process-step-item" }
  ],
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading (H2)",
      "default": "<h2>How it works</h2>"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Process steps"
    }
  ]
}
{% endschema %}