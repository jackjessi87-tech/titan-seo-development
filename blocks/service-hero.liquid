{%- doc -%}
  Reusable service landing page hero block.

  Renders the single visible H1 for a service landing page, a short
  subheading, primary CTAs (call + scroll-to-quote-form) and a trust row.
  The quote button links to the Main Quote Form (#main-quote, see
  blocks/quote-form.liquid) rather than creating a new form per page.

  The trust rating is computed live from the shop's `recent_jobs`
  metaobject, filtered by `rating_filter_keywords` (comma-separated, e.g.
  "sofa, couch" or "piano"). Only real, rated jobs are averaged - if none
  match, the fallback trust text is shown instead of a fabricated number.

  Visual treatment: fixed black/white/red premium look (not the generic
  color-scheme palette) - a glassmorphism trust card, animated CTAs and a
  large fluid H1. All motion is CSS-only (transform/opacity) and gated
  behind prefers-reduced-motion; no JS, no new fonts, no new requests, so
  Core Web Vitals are unaffected. The hero image keeps eager/high-priority
  loading since it is the LCP candidate on pages that set one.

  @param {string} [heading] - block.settings.heading
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign tel_digits = block_settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-'
  assign keywords = block_settings.rating_filter_keywords | split: ','

  assign matched_rating_total = 0
  assign matched_rating_count = 0
  for job in shop.metaobjects.recent_jobs.values
    assign haystack = job.item.value | append: ' ' | append: job.recent_job.value | append: ' ' | append: job.service_type.value | downcase
    assign is_match = false
    for keyword in keywords
      assign trimmed_keyword = keyword | strip | downcase
      if trimmed_keyword != blank and haystack contains trimmed_keyword
        assign is_match = true
      endif
    endfor
    if is_match and job.rating.value != blank
      assign matched_rating_total = matched_rating_total | plus: 0.0 | plus: job.rating.value
      assign matched_rating_count = matched_rating_count | plus: 1
    endif
  endfor
  if matched_rating_count > 0
    assign trust_rating = matched_rating_total | divided_by: matched_rating_count | round: 1
  endif

  assign has_trust_card = false
  if trust_rating != blank or block_settings.fallback_trust_text != blank or block_settings.badge_1 != blank
    assign has_trust_card = true
  endif
%}

<div
  class="service-hero service-hero--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <div class="service-hero__glow" aria-hidden="true"></div>

  <div class="service-hero__inner">
    <div class="service-hero__content">
      {{ block_settings.heading }}

      {%- if block_settings.subheading != blank -%}
        <p class="service-hero__subheading">{{ block_settings.subheading }}</p>
      {%- endif -%}

      <div class="service-hero__ctas">
        {%- if block_settings.phone_number != blank -%}
          <a
            href="tel:{{ tel_digits }}"
            class="button-secondary service-hero__cta service-hero__cta--call"
          >
            {{- block_settings.call_button_text -}}
          </a>
        {%- endif -%}
        <a
          href="{{ block_settings.quote_anchor }}"
          class="button service-hero__cta service-hero__cta--quote"
        >
          <span class="service-hero__cta-label">{{- block_settings.quote_button_text -}}</span>
        </a>
      </div>

      {%- if has_trust_card -%}
        <div class="service-hero__trust-card">
          {%- if trust_rating != blank -%}
            <p class="service-hero__rating">
              <span class="service-hero__rating-star" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.7 7-6.3-3.9L5.7 21l1.7-7L2 9.2l7.1-.6z"/></svg>
              </span>
              {{ trust_rating }} rated on our most recent Sydney jobs
            </p>
          {%- elsif block_settings.fallback_trust_text != blank -%}
            <p class="service-hero__rating">{{ block_settings.fallback_trust_text }}</p>
          {%- endif -%}

          <ul class="service-hero__badges" role="list">
            {%- if block_settings.badge_1 != blank -%}
              <li class="service-hero__badge">
                <span class="service-hero__badge-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="15" height="10" rx="1"></rect></svg>
                </span>
                {{ block_settings.badge_1 }}
              </li>
            {%- endif -%}
            {%- if block_settings.badge_2 != blank -%}
              <li class="service-hero__badge">
                <span class="service-hero__badge-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect></svg>
                </span>
                {{ block_settings.badge_2 }}
              </li>
            {%- endif -%}
            {%- if block_settings.badge_3 != blank -%}
              <li class="service-hero__badge">
                <span class="service-hero__badge-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="19" r="2"></circle><circle cx="17" cy="19" r="2"></circle></svg>
                </span>
                {{ block_settings.badge_3 }}
              </li>
            {%- endif -%}
            {%- if block_settings.badge_4 != blank -%}
              <li class="service-hero__badge">
                <span class="service-hero__badge-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </span>
                {{ block_settings.badge_4 }}
              </li>
            {%- endif -%}
            {%- if block_settings.badge_5 != blank -%}
              <li class="service-hero__badge">
                <span class="service-hero__badge-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path></svg>
                </span>
                {{ block_settings.badge_5 }}
              </li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}
    </div>

    {%- if block_settings.image != blank -%}
      <div class="service-hero__media">
        <img
          src="{{ block_settings.image | image_url: width: 1200 }}"
          srcset="{{ block_settings.image | image_url: width: 600 }} 600w, {{ block_settings.image | image_url: width: 900 }} 900w, {{ block_settings.image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 750px) 45vw, 100vw"
          alt="{{ block_settings.image.alt | default: 'Titan Express van' | escape }}"
          width="{{ block_settings.image.width }}"
          height="{{ block_settings.image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .service-hero {
    --hero-bg-1: #0b0b0c;
    --hero-bg-2: #1a1a1c;
    --hero-fg: #ffffff;
    --hero-fg-muted: rgba(255, 255, 255, 0.72);
    --hero-accent: #e30613;
    --hero-accent-2: #a30410;
    position: relative;
    isolation: isolate;
    padding-block: var(--padding-2xl);
    background: linear-gradient(160deg, var(--hero-bg-1) 0%, var(--hero-bg-2) 100%);
    color: var(--hero-fg);
  }

  .service-hero__glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(60% 55% at 85% 15%, rgba(227, 6, 19, 0.28) 0%, rgba(227, 6, 19, 0) 70%),
      radial-gradient(45% 40% at 10% 90%, rgba(227, 6, 19, 0.14) 0%, rgba(227, 6, 19, 0) 70%);
  }

  .service-hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width, 1280px);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-xl, 32px);
    align-items: center;
    padding-inline: var(--padding-md, 16px);
  }

  @media screen and (min-width: 750px) {
    .service-hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--gap-2xl, 48px);
      padding-inline: var(--padding-xl, 24px);
    }
  }

  .service-hero__content h1 {
    margin: 0 0 var(--margin-md, 16px);
    color: var(--hero-fg);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(2.75rem, 5vw + 1.5rem, 4.75rem);
    text-wrap: balance;
  }

  .service-hero__subheading {
    font-size: var(--font-paragraph-medium--size, 1.125rem);
    color: var(--hero-fg-muted);
    margin: 0 0 var(--margin-xl, 28px);
    max-width: 46ch;
    text-wrap: pretty;
  }

  .service-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm, 12px);
    margin-bottom: var(--margin-xl, 28px);
  }

  .service-hero__cta {
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .service-hero__cta--quote {
    background: linear-gradient(135deg, var(--hero-accent) 0%, var(--hero-accent-2) 100%);
    border: none;
    color: #ffffff;
    box-shadow: 0 4px 18px rgba(227, 6, 19, 0.35);
  }

  .service-hero__cta--quote::after {
    content: "";
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(115deg, transparent, rgba(255, 255, 255, 0.4), transparent);
    transform: skewX(-18deg);
  }

  .service-hero__cta--call {
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    color: var(--hero-fg);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-hero__cta {
      transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    }

    .service-hero__cta--quote::after {
      transition: left 0.5s ease;
    }

    .service-hero__cta--quote:hover,
    .service-hero__cta--quote:focus-visible {
      transform: translateY(-2px) scale(1.02);
      box-shadow: 0 10px 28px rgba(227, 6, 19, 0.45);
    }

    .service-hero__cta--quote:hover::after,
    .service-hero__cta--quote:focus-visible::after {
      left: 130%;
    }

    .service-hero__cta--call:hover,
    .service-hero__cta--call:focus-visible {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.14);
      border-color: var(--hero-accent);
    }
  }

  .service-hero__trust-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border-radius: 18px;
    padding: var(--padding-lg, 20px) var(--padding-xl, 22px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.35);
  }

  .service-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: var(--font-weight-semibold, 600);
    color: var(--hero-fg);
    margin: 0 0 var(--margin-md, 16px);
  }

  .service-hero__rating-star {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: #ffc93c;
  }

  .service-hero__rating-star svg {
    width: 100%;
    height: 100%;
  }

  .service-hero__badges {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 990px) {
    .service-hero__badges {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .service-hero__badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.92);
    font-size: var(--font-paragraph-small--size, 0.875rem);
  }

  .service-hero__badge-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--hero-accent);
  }

  .service-hero__badge-icon svg {
    width: 100%;
    height: 100%;
  }

  .service-hero__media {
    position: relative;
  }

  .service-hero__media img {
    width: 100%;
    height: auto;
    border-radius: 20px;
    display: block;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-hero__content,
    .service-hero__media {
      animation: service-hero-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }

    .service-hero__media {
      animation-delay: 0.1s;
    }

    .service-hero__trust-card {
      animation: service-hero-rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both;
      animation-delay: 0.2s;
    }
  }

  @keyframes service-hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Service hero",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading (H1)",
      "default": "<h1>Service Landing Page</h1>",
      "info": "Keep this the only H1 on the page."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A short, specific description of the service and area it covers."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "0469 717 535"
    },
    {
      "type": "text",
      "id": "call_button_text",
      "label": "Call button label",
      "default": "Call Now"
    },
    {
      "type": "text",
      "id": "quote_button_text",
      "label": "Quote button label",
      "default": "Get a Free Quote"
    },
    {
      "type": "text",
      "id": "quote_anchor",
      "label": "Quote form anchor",
      "default": "#main-quote",
      "info": "Must match the ID of this page's Quote Form block. Do not change unless the form ID changes."
    },
    {
      "type": "header",
      "content": "Trust signal"
    },
    {
      "type": "text",
      "id": "rating_filter_keywords",
      "label": "Recent-jobs keywords (comma-separated)",
      "info": "Matches this page's service against the Recent Jobs metaobject to compute a real average rating. Leave blank to always show the fallback trust text instead."
    },
    {
      "type": "text",
      "id": "fallback_trust_text",
      "label": "Fallback trust text",
      "default": "Trusted by Sydney households and Marketplace buyers.",
      "info": "Shown only when no matching rated jobs are available yet. When rated jobs exist, a real average rating is shown instead."
    },
    {
      "type": "header",
      "content": "Service badges"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "Oversized van"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Protective blankets"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "Trolley and straps"
    },
    {
      "type": "text",
      "id": "badge_4",
      "label": "Badge 4",
      "default": "Same-day availability where scheduling allows"
    },
    {
      "type": "text",
      "id": "badge_5",
      "label": "Badge 5",
      "default": "Sydney-wide service"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Service hero"
    }
  ]
}
{% endschema %}
