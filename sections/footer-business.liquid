{%- doc -%}
  Titan Express Furniture Pickup & Delivery - premium footer.

  Self-contained section: all CSS is scoped under .titan-footer and all
  JavaScript lives in a single {% javascript %} block, so this file has no
  dependency on (and no effect on) any other template, section or asset.

  Structured data note: the optional JSON-LD block below is OFF by default
  ("Enable footer business schema"). Only turn it on if this theme does not
  already render Organization/LocalBusiness schema elsewhere (for example in
  the theme's header section) - turning it on alongside an existing block
  would create duplicate business schema on every page.
{%- enddoc -%}

{% liquid
  assign phone_raw = section.settings.phone | strip
  assign phone_digits = phone_raw | remove: ' ' | remove: '(' | remove: ')' | remove: '-'
  assign phone_first_char = phone_digits | slice: 0, 1
  assign phone_href = phone_digits
  if phone_first_char == '0'
    assign phone_href = phone_digits | remove_first: '0' | prepend: '+61'
  endif

  assign has_rating = false
  if section.settings.rating_value != blank and section.settings.review_count != blank
    assign has_rating = true
  endif

  assign service_link_blocks = section.blocks | where: 'type', 'service_link'
  assign area_link_blocks = section.blocks | where: 'type', 'area_link'
  assign social_link_blocks = section.blocks | where: 'type', 'social_link'

  assign has_legal_links = false
  if section.settings.legal_menu != blank
    if section.settings.legal_menu.links.size > 0
      assign has_legal_links = true
    endif
  endif
%}

<footer
  class="titan-footer"
  style="
    --tf-bg: {{ section.settings.background_color }};
    --tf-text: {{ section.settings.text_color }};
    --tf-muted: {{ section.settings.muted_text_color }};
    --tf-accent: {{ section.settings.accent_color }};
    --tf-border: {{ section.settings.border_color }};
    --tf-pad-top: {{ section.settings.padding_top }}px;
    --tf-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="titan-footer__inner">
    <div class="titan-footer__grid">

      {%- comment -%} 1. Brand column {%- endcomment -%}
      <div class="titan-footer__col titan-footer__col--brand">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              width: section.settings.logo_width,
              alt: section.settings.brand_name,
              loading: 'lazy',
              class: 'titan-footer__logo'
          }}
        {%- else -%}
          <p class="titan-footer__brand-name">{{ section.settings.brand_name | escape }}</p>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="titan-footer__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}

        {%- if section.settings.trust_line != blank -%}
          <p class="titan-footer__trust-line">{{ section.settings.trust_line | escape }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} 2. Services navigation {%- endcomment -%}
      {%- if service_link_blocks.size > 0 -%}
        <nav class="titan-footer__col" aria-label="{{ section.settings.services_heading | escape }}">
          <h2 class="titan-footer__heading">{{ section.settings.services_heading | escape }}</h2>
          <ul class="titan-footer__list" role="list">
            {%- for block in service_link_blocks -%}
              {%- if block.settings.label != blank -%}
                <li class="titan-footer__list-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.url != blank -%}
                    <a class="titan-footer__link" href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a>
                  {%- else -%}
                    <span class="titan-footer__link titan-footer__link--static">{{ block.settings.label | escape }}</span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      {%- comment -%} 3. Service areas {%- endcomment -%}
      {%- if area_link_blocks.size > 0 -%}
        <nav class="titan-footer__col" aria-label="{{ section.settings.areas_heading | escape }}">
          <h2 class="titan-footer__heading">{{ section.settings.areas_heading | escape }}</h2>
          <ul class="titan-footer__list" role="list">
            {%- for block in area_link_blocks -%}
              {%- if block.settings.label != blank -%}
                <li class="titan-footer__list-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.url != blank -%}
                    <a class="titan-footer__link" href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a>
                  {%- else -%}
                    <span class="titan-footer__link titan-footer__link--static">{{ block.settings.label | escape }}</span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      {%- comment -%} 4. Contact and quote area {%- endcomment -%}
      <div class="titan-footer__col titan-footer__col--contact">
        <h2 class="titan-footer__heading">{{ section.settings.contact_heading | escape }}</h2>

        <address class="titan-footer__address">
          {%- if phone_raw != blank -%}
            <a class="titan-footer__phone" href="tel:{{ phone_href }}">
              <span class="titan-footer__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span>Call {{ phone_raw | escape }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.email != blank -%}
            <a class="titan-footer__email" href="mailto:{{ section.settings.email }}">
              <span class="titan-footer__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span>{{ section.settings.email | escape }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <div class="titan-footer__hours rte">{{ section.settings.hours }}</div>
          {%- endif -%}

          {%- if section.settings.service_area_line != blank -%}
            <p class="titan-footer__area-line">{{ section.settings.service_area_line | escape }}</p>
          {%- endif -%}
        </address>

        {%- if section.settings.quote_button_url != blank -%}
          <a class="titan-footer__quote-button" href="{{ section.settings.quote_button_url }}">
            {{ section.settings.quote_button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} 5. Trust and review area {%- endcomment -%}
    {%- if has_rating -%}
      <div class="titan-footer__trust-row">
        <div class="titan-footer__rating">
          <span class="titan-footer__icon titan-footer__icon--star" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </span>
          <span class="titan-footer__rating-text">
            {{ section.settings.rating_value | escape }} &middot; {{ section.settings.review_count | escape }} reviews
          </span>
        </div>
        {%- if section.settings.review_url != blank -%}
          <a class="titan-footer__review-link" href="{{ section.settings.review_url }}">
            Read our reviews
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if social_link_blocks.size > 0 -%}
      <ul class="titan-footer__social" role="list">
        {%- for block in social_link_blocks -%}
          {%- if block.settings.url != blank -%}
            <li {{ block.shopify_attributes }}>
              <a class="titan-footer__social-link" href="{{ block.settings.url }}" aria-label="{{ block.settings.platform | escape }}">
                <span class="titan-footer__icon" aria-hidden="true">
                  {%- case block.settings.platform -%}
                    {%- when 'facebook' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    {%- when 'instagram' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
                    {%- when 'google' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                  {%- endcase -%}
                </span>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- comment -%} 6. Legal navigation {%- endcomment -%}
    <div class="titan-footer__legal">
      <p class="titan-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name | escape }}. All rights reserved.
      </p>

      {%- if has_legal_links -%}
        <nav class="titan-footer__legal-nav" aria-label="Legal">
          <ul class="titan-footer__legal-list" role="list">
            {%- for link in section.settings.legal_menu.links -%}
              <li>
                <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      {%- if section.settings.show_back_to_top -%}
        <button type="button" class="titan-footer__back-to-top" data-titan-footer-top>
          <span>Back to top</span>
          <span class="titan-footer__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
          </span>
        </button>
      {%- endif -%}
    </div>
  </div>
</footer>

{%- if section.settings.enable_schema -%}
  {%- liquid
    assign schema_type_json = section.settings.schema_type | json
    assign name_json = section.settings.brand_name | json
    assign shop_url_json = shop.url | json

    assign ld = '"@context":"https://schema.org","@type":' | append: schema_type_json
    assign ld = ld | append: ',"name":' | append: name_json
    assign ld = ld | append: ',"url":' | append: shop_url_json

    if phone_raw != blank
      assign phone_json = phone_raw | json
      assign ld = ld | append: ',"telephone":' | append: phone_json
    endif

    if section.settings.description != blank
      assign description_plain = section.settings.description | strip_html
      assign description_json = description_plain | json
      assign ld = ld | append: ',"description":' | append: description_json
    endif

    assign area_json = ''
    for block in area_link_blocks
      if block.settings.label != blank
        assign area_label_json = block.settings.label | json
        assign area_json = area_json | append: ',' | append: area_label_json
      endif
    endfor
    assign area_json = area_json | remove_first: ','
    if area_json != blank
      assign ld = ld | append: ',"areaServed":[' | append: area_json | append: ']'
    endif

    assign social_json = ''
    for block in social_link_blocks
      if block.settings.url != blank
        assign social_url_json = block.settings.url | json
        assign social_json = social_json | append: ',' | append: social_url_json
      endif
    endfor
    assign social_json = social_json | remove_first: ','
    if social_json != blank
      assign ld = ld | append: ',"sameAs":[' | append: social_json | append: ']'
    endif
  -%}
  <script type="application/ld+json">{ {{ ld }} }</script>
{%- endif -%}

{% stylesheet %}
  .titan-footer {
    background-color: var(--tf-bg);
    color: var(--tf-text);
    padding-top: var(--tf-pad-top);
    padding-bottom: var(--tf-pad-bottom);
    font-family: inherit;
    line-height: 1.5;
  }

  .titan-footer a {
    color: inherit;
  }

  .titan-footer__inner {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  .titan-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--tf-border);
  }

  @media screen and (min-width: 700px) {
    .titan-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1000px) {
    .titan-footer__grid {
      grid-template-columns: 1.3fr 1fr 1fr 1.2fr;
      gap: 32px;
    }
  }

  .titan-footer__col {
    min-width: 0;
  }

  .titan-footer__logo {
    display: block;
    height: auto;
    margin-bottom: 16px;
  }

  .titan-footer__brand-name {
    margin: 0 0 16px;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .titan-footer__description {
    margin: 0 0 16px;
    max-width: 40ch;
    color: var(--tf-muted);
    font-size: 0.9375rem;
  }

  .titan-footer__description p {
    margin: 0;
  }

  .titan-footer__trust-line {
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--tf-accent);
    text-transform: uppercase;
  }

  .titan-footer__heading {
    margin: 0 0 20px;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--tf-text);
  }

  .titan-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .titan-footer__link {
    display: inline-block;
    text-decoration: none;
    color: var(--tf-muted);
    font-size: 0.9375rem;
    border-bottom: 1px solid transparent;
    padding-block: 2px;
  }

  .titan-footer__link--static {
    cursor: default;
  }

  a.titan-footer__link:hover,
  a.titan-footer__link:focus-visible {
    color: var(--tf-text);
    border-bottom-color: var(--tf-accent);
  }

  .titan-footer__address {
    display: flex;
    flex-direction: column;
    gap: 14px;
    font-style: normal;
    margin-bottom: 20px;
  }

  .titan-footer__phone,
  .titan-footer__email {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.0625rem;
    min-height: 44px;
    color: var(--tf-text);
  }

  .titan-footer__phone:hover,
  .titan-footer__phone:focus-visible,
  .titan-footer__email:hover,
  .titan-footer__email:focus-visible {
    color: var(--tf-accent);
  }

  .titan-footer__hours,
  .titan-footer__hours p {
    margin: 0;
    color: var(--tf-muted);
    font-size: 0.9375rem;
  }

  .titan-footer__area-line {
    margin: 0;
    color: var(--tf-muted);
    font-size: 0.9375rem;
  }

  .titan-footer__quote-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 28px;
    background-color: var(--tf-accent);
    color: #131313;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 6px;
    text-align: center;
  }

  .titan-footer__quote-button:hover,
  .titan-footer__quote-button:focus-visible {
    filter: brightness(1.08);
  }

  .titan-footer__icon {
    display: inline-flex;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .titan-footer__icon svg {
    width: 100%;
    height: 100%;
  }

  .titan-footer__trust-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-block: 24px;
    border-bottom: 1px solid var(--tf-border);
  }

  .titan-footer__rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .titan-footer__icon--star {
    color: var(--tf-accent);
  }

  .titan-footer__rating-text {
    font-size: 0.9375rem;
    color: var(--tf-muted);
  }

  .titan-footer__review-link {
    font-size: 0.9375rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--tf-text);
  }

  .titan-footer__review-link:hover,
  .titan-footer__review-link:focus-visible {
    color: var(--tf-accent);
  }

  .titan-footer__social {
    display: flex;
    gap: 12px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }

  .titan-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--tf-border);
    border-radius: 50%;
    color: var(--tf-muted);
  }

  .titan-footer__social-link:hover,
  .titan-footer__social-link:focus-visible {
    color: var(--tf-accent);
    border-color: var(--tf-accent);
  }

  .titan-footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 24px;
  }

  .titan-footer__copyright {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--tf-muted);
  }

  .titan-footer__legal-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
  }

  .titan-footer__legal-list a {
    text-decoration: none;
    color: var(--tf-muted);
  }

  .titan-footer__legal-list a:hover,
  .titan-footer__legal-list a:focus-visible {
    color: var(--tf-accent);
  }

  .titan-footer__back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    padding: 0 16px;
    background: transparent;
    border: 1px solid var(--tf-border);
    border-radius: 999px;
    color: var(--tf-text);
    font-size: 0.8125rem;
    cursor: pointer;
  }

  .titan-footer__back-to-top:hover,
  .titan-footer__back-to-top:focus-visible {
    color: var(--tf-accent);
    border-color: var(--tf-accent);
  }

  .titan-footer *:focus-visible {
    outline: 2px solid var(--tf-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .titan-footer__link,
    .titan-footer__phone,
    .titan-footer__email,
    .titan-footer__quote-button,
    .titan-footer__social-link,
    .titan-footer__review-link,
    .titan-footer__legal-list a,
    .titan-footer__back-to-top {
      transition: color 0.15s ease, border-color 0.15s ease, filter 0.15s ease;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var buttons = document.querySelectorAll('[data-titan-footer-top]');
    if (!buttons.length) return;

    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    buttons.forEach(function (button) {
      button.addEventListener('click', function () {
        window.scrollTo({
          top: 0,
          behavior: prefersReducedMotion ? 'auto' : 'smooth'
        });
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Titan Express footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Business name",
      "default": "Titan Express Furniture Pickup & Delivery"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Reliable furniture pickup, single-item delivery and man-and-van services across Sydney.</p>"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line",
      "default": "Professional equipment • Furniture protected • Sydney-wide service"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0b0b0c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#b3b3b3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Amber accent",
      "default": "#f5b400"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#2a2a2a"
    },
    {
      "type": "header",
      "content": "Services navigation"
    },
    {
      "type": "text",
      "id": "services_heading",
      "label": "Heading",
      "default": "Services"
    },
    {
      "type": "header",
      "content": "Service areas"
    },
    {
      "type": "text",
      "id": "areas_heading",
      "label": "Heading",
      "default": "Service areas"
    },
    {
      "type": "header",
      "content": "Contact & quote"
    },
    {
