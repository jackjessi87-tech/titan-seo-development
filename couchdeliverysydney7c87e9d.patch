+{%- doc -%}
+  Couch Delivery Sydney - quick service introduction block.
+  Renders a single H2 and an editable richtext paragraph (~180-250 words).
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+%}
+
+<div
+  class="couch-intro couch-intro--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+  style="{% render 'spacing-style', settings: block_settings %}"
+  {{ block.shopify_attributes }}
+>
+  <div class="couch-intro__inner">
+    {{ block_settings.heading }}
+    <div class="couch-intro__body rte">
+      {{ block_settings.body }}
+    </div>
+  </div>
+</div>
+
+{% stylesheet %}
+  .couch-intro__inner {
+    max-width: var(--normal-content-width, 720px);
+    margin-inline: auto;
+    padding-inline: var(--padding-md, 16px);
+  }
+
+  .couch-intro__body {
+    font-size: var(--font-paragraph-medium--size, 1.0625rem);
+    line-height: 1.65;
+  }
+
+  .couch-intro__body p:first-child {
+    margin-block-start: 0;
+  }
+{% endstylesheet %}
+
+{% schema %}
+{
+  "name": "Couch delivery intro",
+  "tag": null,
+  "settings": [
+    {
+      "type": "richtext",
+      "id": "heading",
+      "label": "Heading (H2)",
+      "default": "<h2>Couch pickup and delivery, done the careful way</h2>"
+    },
+    {
+      "type": "richtext",
+      "id": "body",
+      "label": "Body copy",
+      "default": "<p>Titan Express picks up couches and sofas from homes, shops and Facebook Marketplace sellers, then delivers them to houses, apartments and offices across Sydney. Whether it is a compact two-seater or a heavy modular sofa, we bring the right van, protective blankets, a trolley and straps so the piece travels safely from pickup to drop-off.</p><p>Large, modular and fragile couches need extra care. Before we collect, we ask about access at both ends: stairs, lifts, hallway width, doorway clearances and where we can park. This lets us plan the safest route and bring the right number of people, rather than guessing on the day.</p><p>We handle marketplace purchases regularly, coordinating pickup times directly with the seller and checking the couch is as described before it leaves the property. From there it is wrapped, secured and delivered to your address at a time that works for you.</p><p>Our service covers Sydney-wide, from the Inner West and Eastern Suburbs through to Parramatta, the Hills District and Sutherland Shire, so most couch deliveries can be arranged within a day or two of getting in touch, with same-day delivery available where scheduling allows.</p>"
+    },
+    {
+      "type": "header",
+      "content": "Appearance"
+    },
+    {
+      "type": "color_scheme",
+      "id": "color_scheme",
+      "label": "Color scheme",
+      "default": "scheme-1"
+    },
+    {
+      "type": "header",
+      "content": "Padding"
+    },
+    {
+      "type": "range",
+      "id": "padding-block-start",
+      "label": "Top",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    },
+    {
+      "type": "range",
+      "id": "padding-block-end",
+      "label": "Bottom",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 24
+    }
+  ],
+  "presets": [
+    {
+      "name": "Couch delivery intro"
+    }
+  ]
+}
+{% endschema %}
diff --git a/blocks/couch-delivery-schema.liquid b/blocks/couch-delivery-schema.liquid
new file mode 100644
index 0000000..60f3efd
--- /dev/null
+++ b/blocks/couch-delivery-schema.liquid
@@ -0,0 +1,110 @@
+{%- doc -%}
+  Couch Delivery Sydney - structured data block (no visible output).
+
+  Emits only page-specific JSON-LD: Service, WebPage and BreadcrumbList.
+
+  Deliberately does NOT add Organization or LocalBusiness schema, because
+  sections/header.liquid already renders a sitewide Organization JSON-LD
+  block on every page (see the theme SEO audit). Adding another one here
+  would duplicate that schema. Deliberately does NOT add AggregateRating -
+  the store has no verified review metafield/app data to source it from.
+
+  FAQPage schema is intentionally handled inside blocks/couch-faq.liquid
+  instead, so it is only emitted when FAQs are actually visible and always
+  matches the rendered questions/answers exactly.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+  assign service_name = block_settings.service_name | default: page.title
+  assign page_description = block_settings.description
+%}
+
+<script type="application/ld+json">
+  {
+    "@context": "https://schema.org",
+    "@type": "Service",
+    "name": {{ service_name | json }},
+    "serviceType": {{ block_settings.service_type | json }},
+    "description": {{ page_description | json }},
+    "areaServed": {
+      "@type": "City",
+      "name": "Sydney, New South Wales, Australia"
+    },
+    "provider": {
+      "@type": "Organization",
+      "name": {{ shop.name | json }},
+      "url": {{ shop.url | json }}
+    },
+    "url": {{ canonical_url | json }}
+  }
+</script>
+
+<script type="application/ld+json">
+  {
+    "@context": "https://schema.org",
+    "@type": "WebPage",
+    "name": {{ page.title | json }},
+    "url": {{ canonical_url | json }},
+    "description": {{ page_description | json }},
+    "inLanguage": {{ request.locale.iso_code | json }},
+    "isPartOf": {
+      "@type": "WebSite",
+      "name": {{ shop.name | json }},
+      "url": {{ shop.url | json }}
+    }
+  }
+</script>
+
+<script type="application/ld+json">
+  {
+    "@context": "https://schema.org",
+    "@type": "BreadcrumbList",
+    "itemListElement": [
+      {
+        "@type": "ListItem",
+        "position": 1,
+        "name": "Home",
+        "item": {{ shop.url | json }}
+      },
+      {
+        "@type": "ListItem",
+        "position": 2,
+        "name": {{ page.title | json }},
+        "item": {{ canonical_url | json }}
+      }
+    ]
+  }
+</script>
+
+{% schema %}
+{
+  "name": "Couch delivery structured data",
+  "tag": null,
+  "settings": [
+    {
+      "type": "text",
+      "id": "service_name",
+      "label": "Service name",
+      "default": "Couch Delivery Sydney"
+    },
+    {
+      "type": "text",
+      "id": "service_type",
+      "label": "Service type",
+      "default": "Furniture delivery"
+    },
+    {
+      "type": "textarea",
+      "id": "description",
+      "label": "Service / page description",
+      "default": "Couch and sofa pickup and delivery across Sydney, including Facebook Marketplace collections, with protective equipment and experienced handling."
+    }
+  ],
+  "presets": [
+    {
+      "name": "Couch delivery structured data"
+    }
+  ]
+}
+{% endschema %}
diff --git a/blocks/couch-faq.liquid b/blocks/couch-faq.liquid
new file mode 100644
index 0000000..e124de2
--- /dev/null
+++ b/blocks/couch-faq.liquid
@@ -0,0 +1,181 @@
+{%- doc -%}
+  Couch Delivery Sydney - FAQ block.
+
+  Renders an H2 plus an accordion of nested _faq-item blocks (reusing the
+  theme's existing accordion-custom-component snippet and .details/.accordion
+  CSS, so no new accordion behaviour or styling is duplicated).
+
+  Also emits FAQPage JSON-LD built from the exact same nested block settings
+  (via block.blocks), so the structured data can never go out of sync with
+  the visibly rendered questions and answers, and is only emitted when the
+  FAQs are actually visible on the page.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+%}
+
+<div
+  class="couch-faq couch-faq--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+  style="{% render 'spacing-style', settings: block_settings %}"
+  {{ block.shopify_attributes }}
+>
+  <div class="couch-faq__inner">
+    {{ block_settings.heading }}
+
+    <div class="accordion couch-faq__accordion">
+      {% content_for 'blocks' %}
+    </div>
+  </div>
+</div>
+
+{%- assign faq_entries = block.blocks | where: 'type', '_faq-item' -%}
+{%- if faq_entries.size > 0 -%}
+  <script type="application/ld+json">
+    {
+      "@context": "https://schema.org",
+      "@type": "FAQPage",
+      "mainEntity": [
+        {%- for item in faq_entries -%}
+          {
+            "@type": "Question",
+            "name": {{ item.settings.question | strip_html | json }},
+            "acceptedAnswer": {
+              "@type": "Answer",
+              "text": {{ item.settings.answer | strip_html | json }}
+            }
+          }{%- unless forloop.last -%},{%- endunless -%}
+        {%- endfor -%}
+      ]
+    }
+  </script>
+{%- endif -%}
+
+{% stylesheet %}
+  .couch-faq__inner {
+    max-width: var(--normal-content-width, 720px);
+    margin-inline: auto;
+    padding-inline: var(--padding-md, 16px);
+  }
+
+  .couch-faq__accordion {
+    margin-top: var(--margin-lg, 20px);
+  }
+
+  .couch-faq__question {
+    font-weight: var(--font-weight-semibold, 600);
+  }
+
+  .couch-faq__answer {
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+  }
+{% endstylesheet %}
+
+{% schema %}
+{
+  "name": "Couch delivery FAQ",
+  "tag": null,
+  "blocks": [
+    { "type": "_faq-item" }
+  ],
+  "settings": [
+    {
+      "type": "richtext",
+      "id": "heading",
+      "label": "Heading (H2)",
+      "default": "<h2>Couch delivery FAQs</h2>"
+    },
+    {
+      "type": "header",
+      "content": "Appearance"
+    },
+    {
+      "type": "color_scheme",
+      "id": "color_scheme",
+      "label": "Color scheme",
+      "default": "scheme-1"
+    },
+    {
+      "type": "header",
+      "content": "Padding"
+    },
+    {
+      "type": "range",
+      "id": "padding-block-start",
+      "label": "Top",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    },
+    {
+      "type": "range",
+      "id": "padding-block-end",
+      "label": "Bottom",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    }
+  ],
+  "presets": [
+    {
+      "name": "Couch delivery FAQ",
+      "blocks": {
+        "faq-1": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "How much does couch delivery cost in Sydney?",
+            "answer": "<p>Couch delivery pricing depends on the pickup and delivery suburbs, the size and configuration of the couch, whether stairs or lift access is involved, parking distance, how many workers are needed, and how urgent the job is. Send us these details and we will give you an exact, upfront quote before booking.</p>"
+          }
+        },
+        "faq-2": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Can you collect a couch from Facebook Marketplace?",
+            "answer": "<p>Yes. We regularly collect couches and sofas from Facebook Marketplace and other online sellers across Sydney. Send us the listing details, the pickup and delivery suburbs and a photo of the couch, and we will coordinate pickup timing directly with the seller.</p>"
+          }
+        },
+        "faq-3": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Can you move a couch upstairs?",
+            "answer": "<p>Yes, we regularly deliver couches up and down stairs. Let us know about stairs, lift access or narrow hallways when you request your quote so we can bring the right number of workers and equipment on the day.</p>"
+          }
+        },
+        "faq-4": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Do you protect couches during delivery?",
+            "answer": "<p>Yes. Every couch is wrapped in protective blankets and secured with straps in our van, and we use a trolley to move it safely across floors, hallways and driveways.</p>"
+          }
+        },
+        "faq-5": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Can you deliver a sofa on the same day?",
+            "answer": "<p>Same-day couch delivery is available where scheduling allows. Contact us as early in the day as possible with your pickup and delivery suburbs so we can confirm whether a same-day slot is free.</p>"
+          }
+        },
+        "faq-6": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Do I need to help with lifting?",
+            "answer": "<p>No. Our team brings a trolley and straps and handles the lifting and carrying. If a job needs two workers because of the couch size or stairs, we will let you know when confirming your quote.</p>"
+          }
+        },
+        "faq-7": {
+          "type": "_faq-item",
+          "settings": {
+            "question": "Can you move modular and sofa-bed couches?",
+            "answer": "<p>Yes. We deliver modular sofas, sofa beds, corner lounges, recliners and other large or heavy configurations. Let us know the couch type and how many sections it has so we can plan the right van space and access.</p>"
+          }
+        }
+      },
+      "block_order": ["faq-1", "faq-2", "faq-3", "faq-4", "faq-5", "faq-6", "faq-7"]
+    }
+  ]
+}
+{% endschema %}
diff --git a/blocks/feature-grid.liquid b/blocks/feature-grid.liquid
new file mode 100644
index 0000000..75dde06
--- /dev/null
+++ b/blocks/feature-grid.liquid
@@ -0,0 +1,196 @@
+{%- doc -%}
+  Reusable icon feature grid.
+
+  Used on the Couch Delivery Sydney page for three different sections:
+  couch types, why choose Titan Express, and pricing factors. Reusing one
+  block keeps the CSS and markup for repeating icon/heading/text tiles in
+  one place instead of duplicating it per section.
+
+  Heading is rendered as H2. Each nested _feature-grid-item renders its own
+  H3, so heading hierarchy stays H1 > H2 > H3 with no extra H1s.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+  assign columns_desktop = block_settings.columns_desktop
+%}
+
+<div
+  class="feature-grid feature-grid--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+  style="{% render 'spacing-style', settings: block_settings %} --feature-grid-columns-desktop: {{ columns_desktop }};"
+  {{ block.shopify_attributes }}
+>
+  <div class="feature-grid__inner">
+    {%- if block_settings.heading != blank -%}
+      {{ block_settings.heading }}
+    {%- endif -%}
+    {%- if block_settings.intro != blank -%}
+      <p class="feature-grid__intro">{{ block_settings.intro }}</p>
+    {%- endif -%}
+
+    <div class="feature-grid__items">
+      {% content_for 'blocks' %}
+    </div>
+
+    {%- if block_settings.cta_label != blank and block_settings.cta_link != blank -%}
+      <div class="feature-grid__cta">
+        <a href="{{ block_settings.cta_link }}" class="button">{{ block_settings.cta_label }}</a>
+      </div>
+    {%- endif -%}
+  </div>
+</div>
+
+{% stylesheet %}
+  .feature-grid__inner {
+    max-width: var(--page-width, 1280px);
+    margin-inline: auto;
+    padding-inline: var(--padding-md, 16px);
+  }
+
+  .feature-grid__intro {
+    max-width: 65ch;
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+    margin-block: 0 var(--margin-lg, 20px);
+  }
+
+  .feature-grid__items {
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 20px;
+    margin-top: var(--margin-lg, 20px);
+  }
+
+  @media screen and (min-width: 750px) {
+    .feature-grid__items {
+      grid-template-columns: repeat(var(--feature-grid-columns-desktop, 4), minmax(0, 1fr));
+    }
+  }
+
+  .feature-grid__item {
+    display: flex;
+    flex-direction: column;
+    gap: 8px;
+    padding: 20px;
+    border-radius: var(--style-border-radius-buttons-primary, 8px);
+    background: rgb(var(--color-foreground-rgb) / var(--opacity-5-15, 0.05));
+  }
+
+  .feature-grid__icon {
+    width: 32px;
+    height: 32px;
+    color: var(--color-primary);
+  }
+
+  .feature-grid__icon svg {
+    width: 100%;
+    height: 100%;
+  }
+
+  .feature-grid__item-heading {
+    margin: 0;
+    font-size: var(--font-h4--size, 1.125rem);
+  }
+
+  .feature-grid__item-text {
+    margin: 0;
+    font-size: var(--font-paragraph-small--size, 0.9rem);
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+  }
+
+  .feature-grid__cta {
+    margin-top: var(--margin-xl, 28px);
+  }
+{% endstylesheet %}
+
+{% schema %}
+{
