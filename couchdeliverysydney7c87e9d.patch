@@ -0,0 +1,189 @@
+{%- doc -%}
+  Reusable numbered process block.
+
+  Used twice on the Couch Delivery Sydney page: "How the service works"
+  (4 steps) and the Marketplace pickup process (5 steps). One component
+  keeps the numbered-step markup/CSS in one place instead of duplicating it.
+
+  Heading is rendered as H2, each nested _process-step-item renders its own
+  H3, so heading hierarchy stays H1 > H2 > H3.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+%}
+
+<div
+  class="process-steps process-steps--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+  style="{% render 'spacing-style', settings: block_settings %}"
+  {{ block.shopify_attributes }}
+>
+  <div class="process-steps__inner">
+    {%- if block_settings.heading != blank -%}
+      {{ block_settings.heading }}
+    {%- endif -%}
+    {%- if block_settings.intro != blank -%}
+      <p class="process-steps__intro">{{ block_settings.intro }}</p>
+    {%- endif -%}
+
+    <div class="process-steps__items">
+      {% content_for 'blocks' %}
+    </div>
+
+    {%- if block_settings.cta_label != blank and block_settings.cta_link != blank -%}
+      <div class="process-steps__cta">
+        <a href="{{ block_settings.cta_link }}" class="button">{{ block_settings.cta_label }}</a>
+      </div>
+    {%- endif -%}
+  </div>
+</div>
+
+{% stylesheet %}
+  .process-steps__inner {
+    max-width: var(--page-width, 1280px);
+    margin-inline: auto;
+    padding-inline: var(--padding-md, 16px);
+  }
+
+  .process-steps__intro {
+    max-width: 65ch;
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+    margin-block: 0 var(--margin-lg, 20px);
+  }
+
+  .process-steps__items {
+    counter-reset: process-step;
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 24px;
+    margin-top: var(--margin-lg, 20px);
+  }
+
+  @media screen and (min-width: 990px) {
+    .process-steps__items {
+      grid-template-columns: repeat(4, minmax(0, 1fr));
+    }
+  }
+
+  .process-steps__item {
+    position: relative;
+    padding-top: 8px;
+  }
+
+  .process-steps__number {
+    counter-increment: process-step;
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    width: 36px;
+    height: 36px;
+    border-radius: 50%;
+    background: var(--color-primary);
+    color: var(--color-primary-button-text, #fff);
+    font-weight: var(--font-weight-bold, 700);
+    margin-bottom: 10px;
+  }
+
+  .process-steps__number::before {
+    content: counter(process-step);
+  }
+
+  .process-steps__heading {
+    margin: 0 0 6px;
+    font-size: var(--font-h4--size, 1.125rem);
+  }
+
+  .process-steps__text {
+    margin: 0;
+    font-size: var(--font-paragraph-small--size, 0.9rem);
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+  }
+
+  .process-steps__cta {
+    margin-top: var(--margin-xl, 28px);
+  }
+{% endstylesheet %}
+
+{% schema %}
+{
+  "name": "Process steps",
+  "tag": null,
+  "blocks": [
+    { "type": "_process-step-item" }
+  ],
+  "settings": [
+    {
+      "type": "richtext",
+      "id": "heading",
+      "label": "Heading (H2)",
+      "default": "<h2>How it works</h2>"
+    },
+    {
+      "type": "text",
+      "id": "intro",
+      "label": "Intro text (optional)",
+      "default": ""
+    },
+    {
+      "type": "header",
+      "content": "Optional CTA"
+    },
+    {
+      "type": "text",
+      "id": "cta_label",
+      "label": "CTA label",
+      "default": ""
+    },
+    {
+      "type": "url",
+      "id": "cta_link",
+      "label": "CTA link",
+      "info": "Leave both CTA fields blank to hide the button. Use #main-quote to link to the existing quote form."
+    },
+    {
+      "type": "header",
+      "content": "Appearance"
+    },
+    {
+      "type": "color_scheme",
+      "id": "color_scheme",
+      "label": "Color scheme",
+      "default": "scheme-1"
+    },
+    {
+      "type": "header",
+      "content": "Padding"
+    },
+    {
+      "type": "range",
+      "id": "padding-block-start",
+      "label": "Top",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    },
+    {
+      "type": "range",
+      "id": "padding-block-end",
+      "label": "Bottom",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    }
+  ],
+  "presets": [
+    {
+      "name": "Process steps",
+      "blocks": {
+        "step-1": { "type": "_process-step-item" },
+        "step-2": { "type": "_process-step-item" }
+      },
+      "block_order": ["step-1", "step-2"]
+    }
+  ]
+}
+{% endschema %}
diff --git a/blocks/recent-jobs-couch.liquid b/blocks/recent-jobs-couch.liquid
new file mode 100644
index 0000000..8bd1869
--- /dev/null
+++ b/blocks/recent-jobs-couch.liquid
@@ -0,0 +1,248 @@
+{%- doc -%}
+  Couch Delivery Sydney - recent jobs proof block.
+
+  Connects to the store's existing "Recent Jobs" metaobject (type:
+  recent_jobs) instead of hardcoding fake jobs. Prefers entries that
+  mention a couch/sofa; falls back to showing the most recent jobs of any
+  type if none match; renders nothing if the metaobject has no entries at
+  all, so no placeholder/fake content is ever shown.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+  assign all_jobs = shop.metaobjects.recent_jobs.values
+  assign max_jobs = block_settings.max_jobs
+
+  assign matched_count = 0
+  assign fallback_count = 0
+
+  for job in all_jobs
+    assign haystack = job.item.value | append: ' ' | append: job.recent_job.value | append: ' ' | append: job.service_type.value | append: ' ' | append: job.short_description.value | downcase
+    if haystack contains 'sofa' or haystack contains 'couch'
+      assign matched_count = matched_count | plus: 1
+    endif
+    assign fallback_count = fallback_count | plus: 1
+  endfor
+
+  if matched_count > 0
+    assign show_fallback = false
+  elsif fallback_count > 0
+    assign show_fallback = true
+  endif
+%}
+
+{%- if matched_count > 0 or show_fallback -%}
+  <div
+    class="recent-jobs recent-jobs--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+    style="{% render 'spacing-style', settings: block_settings %}"
+    {{ block.shopify_attributes }}
+  >
+    <div class="recent-jobs__inner">
+      {%- if matched_count > 0 -%}
+        {{ block_settings.heading }}
+      {%- else -%}
+        {{ block_settings.fallback_heading }}
+      {%- endif -%}
+
+      <div class="recent-jobs__grid">
+        {%- assign shown = 0 -%}
+        {%- for job in all_jobs -%}
+          {%- if shown >= max_jobs -%}
+            {%- break -%}
+          {%- endif -%}
+          {%- assign haystack = job.item.value | append: ' ' | append: job.recent_job.value | append: ' ' | append: job.service_type.value | append: ' ' | append: job.short_description.value | downcase -%}
+          {%- assign is_match = false -%}
+          {%- if haystack contains 'sofa' or haystack contains 'couch' -%}
+            {%- assign is_match = true -%}
+          {%- endif -%}
+
+          {%- assign should_render_card = false -%}
+          {%- if matched_count > 0 -%}
+            {%- if is_match -%}
+              {%- assign should_render_card = true -%}
+            {%- endif -%}
+          {%- else -%}
+            {%- assign should_render_card = true -%}
+          {%- endif -%}
+
+          {%- if should_render_card -%}
+            <article class="recent-jobs__card">
+              {%- if job.image.value != blank -%}
+                <img
+                  class="recent-jobs__image"
+                  src="{{ job.image.value | image_url: width: 500 }}"
+                  srcset="{{ job.image.value | image_url: width: 400 }} 400w, {{ job.image.value | image_url: width: 700 }} 700w"
+                  sizes="(min-width: 750px) 33vw, 100vw"
+                  alt="{{ job.recent_job.value | default: job.item.value | escape }}"
+                  width="{{ job.image.value.width }}"
+                  height="{{ job.image.value.height }}"
+                  loading="lazy"
+                >
+              {%- else -%}
+                <span class="recent-jobs__image recent-jobs__image--placeholder" aria-hidden="true">
+                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="7" width="15" height="10" rx="1"></rect><path d="M16 10h4l3 3v4h-7z"></path><circle cx="6" cy="19" r="2"></circle><circle cx="18" cy="19" r="2"></circle></svg>
+                </span>
+              {%- endif -%}
+
+              <div class="recent-jobs__card-body">
+                <h3 class="recent-jobs__job-title">{{ job.recent_job.value | default: job.item.value }}</h3>
+                {%- if job.pickup_suburb.value != blank and job.drop_off_suburb.value != blank -%}
+                  <p class="recent-jobs__route">{{ job.pickup_suburb.value | strip }} &rarr; {{ job.drop_off_suburb.value | strip }}</p>
+                {%- endif -%}
+                {%- if job.short_description.value != blank -%}
+                  <p class="recent-jobs__desc">{{ job.short_description.value }}</p>
+                {%- endif -%}
+                {%- if job.rating.value != blank -%}
+                  <p class="recent-jobs__rating"><span aria-hidden="true">&#9733;</span> {{ job.rating.value }}</p>
+                {%- endif -%}
+              </div>
+            </article>
+            {%- assign shown = shown | plus: 1 -%}
+          {%- endif -%}
+        {%- endfor -%}
+      </div>
+    </div>
+  </div>
+{%- endif -%}
+
+{% stylesheet %}
+  .recent-jobs__inner {
+    max-width: var(--page-width, 1280px);
+    margin-inline: auto;
+    padding-inline: var(--padding-md, 16px);
+  }
+
+  .recent-jobs__grid {
+    display: grid;
+    grid-template-columns: 1fr;
+    gap: 20px;
+    margin-top: var(--margin-lg, 20px);
+  }
+
+  @media screen and (min-width: 750px) {
+    .recent-jobs__grid {
+      grid-template-columns: repeat(3, minmax(0, 1fr));
+    }
+  }
+
+  .recent-jobs__card {
+    border-radius: var(--style-border-radius-buttons-primary, 8px);
+    overflow: hidden;
+    background: rgb(var(--color-foreground-rgb) / var(--opacity-5-15, 0.05));
+  }
+
+  .recent-jobs__image {
+    display: block;
+    width: 100%;
+    height: 180px;
+    object-fit: cover;
+  }
+
+  .recent-jobs__image--placeholder {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-35-55, 0.4));
+  }
+
+  .recent-jobs__image--placeholder svg {
+    width: 48px;
+    height: 48px;
+  }
+
+  .recent-jobs__card-body {
+    padding: 16px;
+  }
+
+  .recent-jobs__job-title {
+    margin: 0 0 4px;
+    font-size: var(--font-h4--size, 1.125rem);
+  }
+
+  .recent-jobs__route {
+    margin: 0 0 6px;
+    font-size: var(--font-paragraph-small--size, 0.9rem);
+    font-weight: var(--font-weight-medium, 500);
+  }
+
+  .recent-jobs__desc {
+    margin: 0 0 6px;
+    font-size: var(--font-paragraph-small--size, 0.9rem);
+    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text, 0.75));
+  }
+
+  .recent-jobs__rating {
+    margin: 0;
+    font-size: var(--font-paragraph-small--size, 0.9rem);
+    font-weight: var(--font-weight-semibold, 600);
+  }
+{% endstylesheet %}
+
+{% schema %}
+{
+  "name": "Couch delivery recent jobs",
+  "tag": null,
+  "settings": [
+    {
+      "type": "richtext",
+      "id": "heading",
+      "label": "Heading when couch/sofa jobs are found (H2)",
+      "default": "<h2>Recent couch deliveries</h2>"
+    },
+    {
+      "type": "richtext",
+      "id": "fallback_heading",
+      "label": "Heading when no couch/sofa jobs exist yet (H2)",
+      "default": "<h2>Recent Titan Express deliveries</h2>"
+    },
+    {
+      "type": "range",
+      "id": "max_jobs",
+      "label": "Maximum jobs to show",
+      "min": 1,
+      "max": 6,
+      "step": 1,
+      "default": 3
+    },
+    {
+      "type": "header",
+      "content": "Appearance"
+    },
+    {
+      "type": "color_scheme",
+      "id": "color_scheme",
+      "label": "Color scheme",
+      "default": "scheme-1"
+    },
+    {
+      "type": "header",
+      "content": "Padding"
+    },
+    {
+      "type": "range",
+      "id": "padding-block-start",
+      "label": "Top",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    },
+    {
+      "type": "range",
+      "id": "padding-block-end",
+      "label": "Bottom",
+      "min": 0,
+      "max": 100,
+      "step": 1,
+      "unit": "px",
+      "default": 48
+    }
+  ],
+  "presets": [
+    {
+      "name": "Couch delivery recent jobs"
+    }
+  ]
+}
+{% endschema %}
diff --git a/blocks/service-areas.liquid b/blocks/service-areas.liquid
new file mode 100644
index 0000000..5fb990b
--- /dev/null
+++ b/blocks/service-areas.liquid
@@ -0,0 +1,168 @@
+{%- doc -%}
+  Couch Delivery Sydney - service areas block.
+
+  Renders an H2, a short intro, and a list of Sydney regions as plain text
+  chips (no links). Deliberately avoids generating dozens of per-suburb
+  links; only two known-existing internal pages are linked, both passed in
+  as explicit URL settings so no link can point to a page that does not
+  exist in the store.
+{%- enddoc -%}
+
+{% liquid
+  assign block_settings = block.settings
+  assign areas = block_settings.areas | newline_to_br | split: '<br />'
+%}
+
+<div
+  class="service-areas service-areas--{{ block.id }} color-{{ block_settings.color_scheme }} spacing-style"
+  style="{% render 'spacing-style', settings: block_settings %}"
+  {{ block.shopify_attributes }}
+>
+  <div class="service-areas__inner">
+    {{ block_settings.heading }}
+
+    {%- if block_settings.intro != blank -%}
+      <p class="service-areas__intro">{{ block_settings.intro }}</p>
+    {%- endif -%}
+
+    <ul class="service-areas__list" role="list">
+      {%- for area in areas -%}
+        {%- assign area_trimmed = area | strip -%}
+        {%- if area_trimmed != blank -%}
+          <li class="service-areas__chip">{{ area_trimmed }}</li>
+        {%- endif -%}
